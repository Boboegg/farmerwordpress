<script>
document.addEventListener('DOMContentLoaded',function(){

  /* 各農事類型對應的預設風險項目和說明 */
  var typeProfiles={
    outdoor:{
      checks:['hours','heat','posture','noppe'],
      hint:'露天耕作常見風險：長時間日曬、高溫、彎腰作業。美國 OSHA 將「高溫」、「紫外線」列為農業重要物理性危害。如果您還需要搬運重物或操作農機，請自行加勾。'
    },
    greenhouse:{
      checks:['heat','enclosed','posture','chemical'],
      hint:'溫室作業常見風險：密閉空間高溫高濕、農藥殘留濃度高、長時間蹲姿。OSHA 研究指出溫室內「呼吸系統危害」顯著提高（黎菌孢子、殘留藥氣）。'
    },
    pesticide:{
      checks:['chemical','noppe','hours'],
      hint:'農藥噴灑常見風險：藥劑經皮膚吸收和呼吸吸入。世界衛生組織指出，直接接觸農藥的工作者面臨最高健康風險，全球使用超過 1,000 種農藥。如果在溫室內噴藥，密閉空間會讓風險更高，請加勾「密閉空間」。'
    },
    machine:{
      checks:['machine','hours','noppe'],
      hint:'農機操作常見風險：噪音超過 85 分貝、振動傷害、捲入翻覆。CDC/NIOSH 統計顯示「接觸物件與設備」是農業死亡主要原因之一。操作鏈鋸等手持振動工具的時間越長越危險。'
    },
    harvest:{
      checks:['heavy','posture','hours','heat'],
      hint:'採收搬運常見風險：反覆搬重物傷腰、長時間蹲姿傷膝蓋、高處採果有墜落風險。NIOSH 統計顯示跌倒佔農業傷害 29%，是農業非致死傷害的首要原因。'
    }
  };

  var selectedType=null;
  var typeButtons=document.querySelectorAll('.prevQ-quiz-type');
  var allChecks=document.querySelectorAll('.prevQ-risk-check');
  var allItems=document.querySelectorAll('.prevQ-check-item');
  var hintBox=document.getElementById('type-hint');
  var hintText=document.getElementById('type-hint-text');

  /* Step 1: 選擇農事類型 → 自動預勾 + 顯示提示 */
  typeButtons.forEach(function(btn){
    btn.addEventListener('click',function(){
      var type=this.getAttribute('data-type');
      selectedType=type;

      /* UI: 按鈕高亮 */
      typeButtons.forEach(function(b){b.classList.remove('is-selected');});
      this.classList.add('is-selected');

      /* 清除所有勾選和高亮 */
      allChecks.forEach(function(cb){cb.checked=false;});
      allItems.forEach(function(item){item.classList.remove('is-highlighted');});

      /* 預勾對應項目 */
      var profile=typeProfiles[type];
      if(profile){
        profile.checks.forEach(function(key){
          var item=document.querySelector('.prevQ-check-item[data-key="'+key+'"]');
          if(item){
            item.querySelector('input').checked=true;
            item.classList.add('is-highlighted');
          }
        });
        hintText.textContent=profile.hint;
        hintBox.style.display='flex';
      }

      updateResult();
    });
  });

  /* Step 2: 勾選變更時更新結果 */
  allChecks.forEach(function(cb){
    cb.addEventListener('change',updateResult);
  });

  /* 計算結果 */
  function updateResult(){
    var circle=document.getElementById('prevQ-risk-circle');
    var countEl=document.getElementById('prevQ-risk-count');
    var textEl=document.getElementById('prevQ-risk-text');
    var displayEl=document.getElementById('prevQ-risk-display');

    var n=document.querySelectorAll('.prevQ-risk-check:checked').length;
    countEl.textContent=n;

    circle.className='prevQ-result-circle';
    displayEl.className='prevQ-result-display';

    if(!selectedType){
      textEl.innerHTML='請先在上方選擇您的農事類型。';
      return;
    }

    /* 根據農事類型產生客製建議 */
    var typeAdvice={
      outdoor:'建議穿戴防曬衣物（UPF 50+）和護膝，高溫時段避免作業。',
      greenhouse:'建議確認溫室通風是否良好，並穿戴呼吸防護具。詳情可參考「溫室專區」。',
      pesticide:'建議穿戴防毒面具（含有機蒸氣濾罐）和耐化學手套，噴藥後遵守再進入間隔時間。',
      machine:'建議穿戴防噪耳罩和護目鏡，並確認農機防護罩和安全連鎖功能正常。',
      harvest:'建議使用搬運車取代肩扛、穿戴護膝、使用升降平台取代梯子。'
    };

    var advice=typeAdvice[selectedType]||'';

    if(n<=2){
      circle.classList.add('prevQ-risk-green');
      displayEl.classList.add('prevQ-border-green');
      textEl.innerHTML='<strong style="color:#2E7D32;">🟢 低度風險（'+n+' 項）</strong><br>'
        +'您目前的風險在可控範圍內。維持現有防護習慣即可。<br>'
        +'<span style="color:#6b7280;font-size:.9rem;">針對您的農事：'+advice+'</span>';
    }else if(n<=5){
      circle.classList.add('prevQ-risk-orange');
      displayEl.classList.add('prevQ-border-orange');
      textEl.innerHTML='<strong style="color:#E65100;">🟠 中度風險（'+n+' 項）</strong><br>'
        +'有一定風險，建議往上查看「防護裝備型錄」，確認您有沒有穿戴對的防護具。<br>'
        +'<span style="color:#6b7280;font-size:.9rem;">針對您的農事：'+advice+'</span>';
    }else{
      circle.classList.add('prevQ-risk-red');
      displayEl.classList.add('prevQ-border-red');
      textEl.innerHTML='<strong style="color:#C62828;">🔴 高度風險（'+n+' 項）</strong><br>'
        +'風險偏高，光靠防護具效果有限。建議優先考慮導入省力農機，從根本改善作業方式。<br>'
        +'<span style="color:#6b7280;font-size:.9rem;">針對您的農事：'+advice+'</span>';
    }
  }
});
</script>



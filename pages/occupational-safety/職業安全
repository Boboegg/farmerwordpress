.prev-tab-btn.is-active,.prev-tab-btn:hover{background:var(--brand-legacy);color:#fff;border-color:var(--brand-legacy);}
.prev-tab-panel{display:none;}
.prev-tab-panel.is-active{display:block;}

/* Tab Intro */
.prev-tab-intro{display:flex;justify-content:space-between;align-items:flex-start;background:#fff;padding:24px;border-radius:12px;margin-bottom:24px;border:1px solid #f0f0f0;flex-wrap:wrap;gap:16px;}

<script>
document.addEventListener('DOMContentLoaded',function(){
  var levels=document.querySelectorAll('.prev-h-level');
  levels.forEach(function(level){
    level.querySelector('.prev-h-bar').addEventListener('click',function(){
      var isOpen=level.classList.contains('is-open');
      levels.forEach(function(l){l.classList.remove('is-open');});
      if(!isOpen) level.classList.add('is-open');
    });
  });
});
</script>
/* Hero */
.mach-hero{padding:36px;background:linear-gradient(135deg,#e3f2fd 0%,#fff 60%,#bbdefb 100%);border-radius:var(--radius);margin-bottom:36px;border:1px solid rgba(21,101,192,.1);}
.mach-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(14,165,233,.1);color:#0ea5e9;padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:14px;}
.mach-hero-title{font-size:2rem;font-weight:900;color:var(--color-info);margin:0 0 8px;line-height:1.3;}
.mach-hero-subtitle{font-size:1.1rem;color:#0ea5e9;font-weight:600;margin:0 0 18px;}
.mach-hero-intro{background:rgba(255,255,255,.75);border-radius:12px;padding:20px;margin-bottom:20px;border:1px solid rgba(21,101,192,.06);}
.mach-hero-intro p{margin:0 0 10px;line-height:1.8;font-size:1rem;}.mach-hero-intro p:last-child{margin-bottom:0;}
.mach-back-link{display:inline-flex;align-items:center;gap:6px;color:var(--brand-legacy);font-weight:700;text-decoration:none;font-size:.9rem;}
.mach-back-link:hover{text-decoration:underline;}
.mach-hero-data{background:rgba(21,101,192,.06);border-left:4px solid var(--color-info);border-radius:8px;padding:16px 20px;margin-top:16px;font-size:.93rem;line-height:1.8;}
.mach-hero-data p{margin:0 0 8px;font-weight:700;color:var(--color-info);}
.mach-hero-data ul{margin:0;padding:0 0 0 20px;}
.mach-hero-data li{margin-bottom:4px;color:var(--text-secondary);}

/* Category Cards */
.mach-categories{display:flex;flex-direction:column;gap:24px;margin-bottom:36px;}
.mach-cat-card{background:#fff;border-radius:var(--radius);overflow:hidden;box-shadow:0 4px 12px rgba(0,0,0,.04);border:1px solid #eee;}
.mach-cat-header{display:flex;align-items:center;gap:16px;padding:24px;background:rgba(0,0,0,.015);border-bottom:1px solid var(--color-bg-elevated);}
.mach-cat-icon{width:52px;height:52px;border-radius:14px;background:rgba(0,0,0,.04);display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--cat-color);flex-shrink:0;}
.mach-cat-header h2{font-size:1.2rem;font-weight:800;color:var(--cat-color);margin:0 0 6px;}
.mach-cat-pain{font-size:.9rem;color:var(--text-secondary);margin:0;line-height:1.6;display:flex;align-items:flex-start;gap:6px;}
.mach-cat-pain i{color:var(--color-warn);margin-top:3px;flex-shrink:0;}
.mach-cat-body{padding:24px;}

/* Equipment Grid */
.mach-equip-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;}
.mach-equip-item{display:flex;gap:14px;padding:18px;background:var(--color-bg-elevated);border-radius:12px;border:1px solid var(--color-bg-elevated);}
.mach-equip-icon{width:44px;height:44px;border-radius:10px;background:rgba(0,0,0,.04);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.mach-equip-item h4{font-size:1rem;font-weight:700;margin:0 0 6px;color:var(--text-primary);}
.mach-equip-item p{font-size:.9rem;line-height:1.6;color:var(--text-secondary);margin:0 0 8px;}
.mach-subsidy{display:inline-flex;align-items:center;gap:6px;background:rgba(212,160,23,.1);color:#b8860b;padding:5px 12px;border-radius:6px;font-size:.82rem;font-weight:700;}

/* Subsidy Section */
.mach-subsidy-section{margin-bottom:36px;}
.mach-subsidy-header{margin-bottom:20px;}
.mach-subsidy-header h2{font-size:1.4rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:10px;margin:0 0 8px;}
.mach-subsidy-header p{color:var(--text-secondary);margin:0;font-size:.95rem;line-height:1.7;}
.mach-subsidy-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;margin-bottom:28px;}
.mach-info-card{background:#fff;border-radius:12px;padding:20px;border:1px solid #eee;box-shadow:0 2px 8px rgba(0,0,0,.03);}
.mach-info-icon{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:12px;}
.mach-info-card h4{font-size:.95rem;font-weight:700;margin:0 0 6px;color:var(--text-primary);}
.mach-info-card p{font-size:.9rem;line-height:1.6;color:var(--text-secondary);margin:0;}

/* Apply Steps */
.mach-apply-steps{background:#fff;border-radius:var(--radius);padding:28px;border:1px solid #eee;margin-bottom:20px;}
.mach-apply-steps h3{font-size:1.1rem;font-weight:800;color:var(--brand-legacy-dark);margin:0 0 20px;}
.mach-steps-row{display:flex;align-items:flex-start;gap:8px;flex-wrap:wrap;justify-content:center;}
.mach-step{flex:1;min-width:160px;text-align:center;padding:16px;}
.mach-step-num{width:36px;height:36px;border-radius:50%;background:var(--brand-legacy);color:#fff;font-weight:900;font-size:1rem;display:inline-flex;align-items:center;justify-content:center;margin-bottom:10px;}
.mach-step h4{font-size:.95rem;font-weight:700;margin:0 0 6px;color:var(--text-primary);}
.mach-step p{font-size:.85rem;line-height:1.5;color:var(--text-secondary);margin:0;}
.mach-step-arrow{display:flex;align-items:center;color:#d0d0d0;font-size:1.2rem;padding-top:20px;}

.mach-subsidy-cta{text-align:center;}
.mach-cta-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:var(--brand-legacy);color:#fff;border-radius:50px;font-weight:700;font-size:.95rem;text-decoration:none;box-shadow:0 4px 12px rgba(92,134,7,.3);transition:all .3s;}
.mach-cta-btn:hover{background:#4a6b05;transform:translateY(-2px);}

/* Safety */
.mach-safety-section{margin-bottom:36px;}
.mach-safety-section h2{font-size:1.4rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:10px;margin:0 0 8px;}
.mach-safety-section>p{color:var(--text-secondary);margin:0 0 16px;font-size:.95rem;line-height:1.7;}
.mach-safety-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
.mach-safety-item{background:#fff;border-radius:12px;padding:20px;border:1px solid #eee;box-shadow:0 2px 8px rgba(0,0,0,.03);}
.mach-safety-item>i{font-size:1.4rem;color:var(--brand-legacy);margin-bottom:10px;display:block;}
.mach-safety-item h4{font-size:.95rem;font-weight:700;margin:0 0 6px;color:var(--text-primary);}
.mach-safety-item p{font-size:.9rem;line-height:1.6;color:var(--text-secondary);margin:0;}

/* References */
.mach-references{background:var(--color-bg-elevated);border-radius:var(--radius);padding:28px;border:1px solid #eee;margin-bottom:36px;}
.mach-references h2{font-size:1.3rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:10px;margin:0 0 16px;}
.mach-ref-list{display:flex;flex-direction:column;gap:8px;}
.mach-ref-list p{font-size:.88rem;line-height:1.6;color:var(--text-secondary);margin:0;padding-left:20px;text-indent:-20px;}
.mach-ref-list a{color:var(--brand-legacy);word-break:break-all;}

@media(max-width:768px){
  .mach-hero{padding:24px;}.mach-hero-title{font-size:1.5rem;}
  .mach-equip-grid{grid-template-columns:1fr;}
  .mach-subsidy-grid{grid-template-columns:1fr;}
  .mach-safety-grid{grid-template-columns:1fr;}
  .mach-steps-row{flex-direction:column;align-items:center;}
  .mach-step-arrow{transform:rotate(90deg);padding:0;}
}
</style>
</div>

<style>
/* === 01-hero 專用樣式 === */
.prev-hero{
  --brand:#5C8607;--brand-hover:#4a6b05;--brand-dark:#2c5e2e;
  --text-primary:#1f2937;--text-secondary:#6b7280;--radius:16px;
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);
  display:flex;gap:40px;align-items:flex-start;padding:40px;
  background:linear-gradient(135deg,#f0f5e8 0%,#fff 60%,#e8f0da 100%);
  border-radius:var(--radius);margin-bottom:0;
  border:1px solid rgba(92,134,7,.1);box-sizing:border-box;
}
.prev-hero *{box-sizing:border-box;}
.prev-hero-content{flex:1.2;}
.prev-hero-visual{flex:.8;position:sticky;top:20px;}
.prev-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(92,134,7,.1);color:var(--brand);padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:16px;}
.prev-hero-title{font-size:2.2rem;font-weight:900;color:var(--brand-dark);margin:0 0 8px;line-height:1.2;}
.prev-hero-subtitle{font-size:1.15rem;color:var(--brand);font-weight:600;margin:0 0 20px;}

/* 導讀段落 */
.prev-hero-intro{background:rgba(255,255,255,.7);border-radius:12px;padding:24px;margin-bottom:24px;border:1px solid rgba(92,134,7,.08);}
.prev-hero-intro p{font-size:1rem;line-height:1.8;color:var(--text-primary);margin:0 0 12px;}
.prev-hero-intro p:last-child{margin-bottom:0;}
.prev-hero-list{list-style:none;padding:0;margin:0 0 16px;}
.prev-hero-list li{display:flex;align-items:flex-start;gap:10px;font-size:.95rem;line-height:1.7;padding:4px 0;color:var(--text-primary);}
.prev-hero-list li i{color:var(--brand);margin-top:4px;flex-shrink:0;}
.prev-hero-note{background:rgba(212,160,23,.08);border-radius:10px;padding:14px 18px;font-size:.93rem;line-height:1.7;display:flex;align-items:flex-start;gap:10px;margin-top:4px;}
.prev-hero-note i{color:#D4A017;margin-top:3px;flex-shrink:0;}

/* CTA */
.prev-hero-actions{display:flex;gap:12px;flex-wrap:wrap;}
.prev-btn-primary,.prev-btn-secondary{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border-radius:50px;font-weight:700;font-size:.95rem;text-decoration:none;transition:all .3s ease;}
.prev-btn-primary{background:var(--brand);color:#fff;box-shadow:0 4px 12px rgba(92,134,7,.3);}
.prev-btn-primary:hover{background:var(--brand-hover);transform:translateY(-2px);}
.prev-btn-secondary{background:#fff;color:var(--brand);border:2px solid var(--brand);}
.prev-btn-secondary:hover{background:var(--brand);color:#fff;}

/* Stats */
.prev-hero-stats{display:flex;flex-direction:column;gap:16px;}
.prev-stat-item{display:flex;align-items:center;gap:16px;background:#fff;padding:16px 20px;border-radius:12px;box-shadow:0 4px 12px rgba(0,0,0,.04);}
.prev-stat-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.prev-stat-number{font-size:1.5rem;font-weight:900;display:block;line-height:1;}
.prev-stat-label{font-size:.85rem;color:var(--text-secondary);}
.prev-stat-source{font-size:.72rem;color:#9ca3af;display:block;margin-top:2px;font-weight:400;}

/* 平滑捲動 */
@media(max-width:768px){
  .prev-hero{flex-direction:column;padding:24px;gap:24px;}
  .prev-hero-title{font-size:1.6rem;}
  .prev-hero-visual{position:static;}
  .prev-hero-stats{flex-direction:row;flex-wrap:wrap;gap:10px;}
  .prev-stat-item{flex:1;min-width:140px;padding:12px;}
}
</style>

<script>
/* 平滑捲動（放在第一塊，全頁共用） */
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('a[href^="#"]').forEach(function(a){
    a.addEventListener('click',function(e){
      var t=document.querySelector(this.getAttribute('href'));
      if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}
    });
  });
});
</script>
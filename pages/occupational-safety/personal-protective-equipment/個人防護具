<!-- ========== CSS ========== -->
<style>
/* PPE 子頁面 */
.ppe-hero,.ppe-categories,.ppe-sop-section,.ppe-legal-section,.ppe-references{
  --brand-legacy:var(--color-brand);--brand-legacy-dark:var(--color-brand-deep);--text-primary:var(--color-text);--text-secondary:var(--color-muted);--radius:16px;
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);box-sizing:border-box;
}
.ppe-hero *,.ppe-categories *,.ppe-sop-section *,.ppe-legal-section *,.ppe-references *{box-sizing:border-box;}

/* Hero */
.ppe-hero{padding:36px;background:linear-gradient(135deg,#fce4ec 0%,#fff 60%,#f8bbd0 100%);border-radius:var(--radius);margin-bottom:36px;border:1px solid rgba(198,40,40,.1);}
.ppe-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(198,40,40,.1);color:var(--color-warn);padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:14px;}
.ppe-hero-title{font-size:2rem;font-weight:900;color:var(--color-warn);margin:0 0 8px;line-height:1.3;}
.ppe-hero-subtitle{font-size:1.1rem;color:#e53935;font-weight:600;margin:0 0 18px;}
.ppe-hero-intro{background:rgba(255,255,255,.75);border-radius:12px;padding:20px;margin-bottom:20px;border:1px solid rgba(198,40,40,.06);}
.ppe-hero-intro p{margin:0 0 10px;line-height:1.8;font-size:1rem;}.ppe-hero-intro p:last-child{margin-bottom:0;}
.ppe-back-link{display:inline-flex;align-items:center;gap:6px;color:var(--brand-legacy);font-weight:700;text-decoration:none;font-size:.9rem;}
.ppe-back-link:hover{text-decoration:underline;}
.ppe-hero-data{background:rgba(198,40,40,.06);border-left:4px solid var(--color-warn);border-radius:8px;padding:16px 20px;margin-top:16px;font-size:.93rem;line-height:1.8;}
.ppe-hero-data p{margin:0 0 8px;font-weight:700;color:var(--color-warn);}
.ppe-hero-data ul{margin:0;padding:0 0 0 20px;}
.ppe-hero-data li{margin-bottom:4px;color:var(--text-secondary);}

/* Category Cards */
.ppe-categories{display:flex;flex-direction:column;gap:24px;margin-bottom:36px;}
.ppe-cat-card{background:#fff;border-radius:var(--radius);overflow:hidden;box-shadow:0 4px 12px rgba(0,0,0,.04);border:1px solid #eee;}
.ppe-cat-header{display:flex;align-items:center;gap:16px;padding:24px;background:rgba(0,0,0,.015);border-bottom:1px solid var(--color-bg-elevated);}
.ppe-cat-icon{width:52px;height:52px;border-radius:14px;background:rgba(0,0,0,.04);display:flex;align-items:center;justify-content:center;font-size:22px;color:var(--cat-color);flex-shrink:0;}
.ppe-cat-header h2{font-size:1.2rem;font-weight:800;color:var(--cat-color);margin:0 0 4px;}
.ppe-cat-why{font-size:.9rem;color:var(--text-secondary);margin:0;line-height:1.6;}
.ppe-cat-body{padding:24px;}

/* Equipment Grid */
.ppe-equip-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:16px;}
.ppe-equip-item{display:flex;gap:14px;padding:18px;background:var(--color-bg-elevated);border-radius:12px;border:1px solid var(--color-bg-elevated);}
.ppe-equip-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.ppe-equip-item h4{font-size:1rem;font-weight:700;margin:0 0 4px;color:var(--text-primary);}
.ppe-equip-when{font-size:.8rem;color:var(--brand-legacy);font-weight:600;margin:0 0 6px;}
.ppe-equip-item p{font-size:.9rem;line-height:1.6;color:var(--text-secondary);margin:0;}

/* Warning box */
.ppe-warning-box{margin-top:16px;padding:14px 18px;background:#fff3e0;border-radius:10px;border-left:4px solid #e65100;font-size:.9rem;line-height:1.7;color:#e65100;display:flex;align-items:flex-start;gap:10px;}
.ppe-warning-box i{margin-top:3px;flex-shrink:0;}

/* SOP */
.ppe-sop-section{margin-bottom:36px;}
.ppe-sop-header{margin-bottom:20px;}
.ppe-sop-header h2{font-size:1.4rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:10px;margin:0 0 8px;}
.ppe-sop-header p{color:var(--text-secondary);margin:0;font-size:.95rem;line-height:1.7;}
.ppe-sop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:20px;}
.ppe-sop-card{background:#fff;border-radius:var(--radius);padding:28px;box-shadow:0 4px 12px rgba(0,0,0,.04);border:1px solid #eee;}
.ppe-sop-card h3{font-size:1.1rem;font-weight:800;margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.ppe-sop-on h3{color:var(--color-brand);}.ppe-sop-off h3{color:var(--color-warn);}
.ppe-sop-card ol{margin:0;padding:0 0 0 20px;counter-reset:sop;}
.ppe-sop-card li{font-size:.93rem;line-height:1.7;margin-bottom:10px;color:var(--text-primary);}
.ppe-highlight{background:rgba(255,235,59,.3);padding:2px 6px;border-radius:4px;font-weight:700;}
.ppe-sop-note{margin:16px 0 0;padding:12px 16px;background:#f0f5e8;border-radius:8px;font-size:.9rem;line-height:1.6;color:var(--brand-legacy-dark);display:flex;align-items:flex-start;gap:8px;}
.ppe-sop-note i{color:var(--brand-legacy);margin-top:2px;flex-shrink:0;}

/* Legal */
.ppe-legal-section{margin-bottom:36px;}
.ppe-legal-section h2{font-size:1.4rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:10px;margin:0 0 8px;}
.ppe-legal-section>p{color:var(--text-secondary);margin:0 0 16px;font-size:.95rem;line-height:1.7;}
.ppe-legal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;}
.ppe-legal-item{background:#fff;border-radius:12px;padding:20px;border:1px solid #eee;box-shadow:0 2px 8px rgba(0,0,0,.03);}
.ppe-legal-item h4{font-size:.95rem;font-weight:700;margin:0 0 8px;color:var(--brand-legacy-dark);}
.ppe-legal-item p{font-size:.9rem;line-height:1.6;color:var(--text-secondary);margin:0;}

/* References */
.ppe-references{background:var(--color-bg-elevated);border-radius:var(--radius);padding:28px;border:1px solid #eee;margin-bottom:36px;}
.ppe-references h2{font-size:1.3rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:10px;margin:0 0 16px;}
.ppe-ref-list{display:flex;flex-direction:column;gap:8px;}
.ppe-ref-list p{font-size:.88rem;line-height:1.6;color:var(--text-secondary);margin:0;padding-left:20px;text-indent:-20px;}
.ppe-ref-list a{color:var(--brand-legacy);word-break:break-all;}

@media(max-width:768px){
  .ppe-hero{padding:24px;}
  .ppe-hero-title{font-size:1.5rem;}
  .ppe-equip-grid{grid-template-columns:1fr;}
  .ppe-sop-grid{grid-template-columns:1fr;}
  .ppe-legal-grid{grid-template-columns:1fr;}
}
</style>
</div>

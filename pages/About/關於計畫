<style>
/* 1. 操作說明書 (Maintenance Guide) */
/* - 替換照片：請修改 <img src="..."> 中的網址。
   - 修改顏色：搜尋 #5d6d3d (尊嚴綠) 並替換。
   - 調整排版：修改 grid-template-columns 的設定。
*/

/* 2. 網格容器 */
.team-grid-container {
    display: grid;
    /* 電腦版：自動填滿，每張卡片最窄 280px */
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
    gap: 30px; 
    padding: 40px 0;
    max-width: 1200px;
    margin: 0 auto;
}

/* 3. 成員卡片 */
.team-member-card {
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05); /* 靜態時的柔和陰影 */
    border: 1px solid rgba(0,0,0,0.05);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); /* 平滑過渡 */
    display: flex;
    flex-direction: column;
    text-align: center;
}

/* 懸停互動效果 */
.team-member-card:hover {
    transform: translateY(-8px); /* 向上浮起 */
    box-shadow: 0 15px 30px rgba(93, 109, 61, 0.15); /* 綠色光暈陰影 */
    border-color: #5d6d3d; /* 邊框變色 */
}

/* 4. 照片區域 */
.member-photo {
    width: 100%;
    height: 260px; /* 統一高度，確保整齊 */
    overflow: hidden;
    position: relative;
    background-color: #f5f5f5;
}

.member-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* 自動填滿裁切 */
    object-position: top center; /* 以人臉為中心 */
    transition: transform 0.5s ease;
}

.team-member-card:hover .member-photo img {
    transform: scale(1.05); /* 懸停時照片微放大 */
}

/* 5. 文字資訊區域 */
.member-info {
    padding: 25px 20px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* 單位標籤 */
.member-org {
    background: rgba(93, 109, 61, 0.1);
    color: #5d6d3d;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 50px;
    margin-bottom: 12px;
    display: inline-block;
}

/* 姓名 */
.member-name {
    margin: 0 0 5px 0;
    font-size: 1.3rem;
    font-weight: 800;
    color: #333;
    letter-spacing: 1px;
}

/* 職稱 */
.member-title {
    margin: 0 0 15px 0;
    font-size: 1rem;
    color: var(--brand);
    font-weight: 600;
    border-bottom: 2px solid #f0f0f0;
    padding-bottom: 10px;
    width: 80%;
}

/* 簡介文字 */
.member-desc {
    font-size: 1.05rem;
    color: #444;
    line-height: 1.8;
}

/* 手機版微調 */
@media (max-width: 768px) {
    .team-grid-container {
        grid-template-columns: 1fr; /* 手機單欄 */
        gap: 20px;
        padding: 20px;
    }
    .member-photo {
        height: 300px; /* 手機版照片拉高，更清晰 */
    }
}

<!-- ========== CSS ========== -->
<style>
/* === 全域變數 === */
.edu-hero,.edu-sections{
  --brand:#5C8607;--brand-dark:#4a6b05;--brand-light:#eef5ea;--brand-hover:#3d5a04;
  --accent:#D4A017;--text-primary:#1f2937;--text-secondary:#555;
  --radius:16px;--shadow:0 4px 16px rgba(0,0,0,.06);
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);box-sizing:border-box;
}
.edu-hero *,.edu-sections *{box-sizing:border-box;}

/* === Hero === */
.edu-hero{display:flex;gap:40px;align-items:center;padding:48px 40px;background:linear-gradient(135deg,var(--brand-light) 0%,#fff 60%,#f0f4e8 100%);border-radius:var(--radius);margin-bottom:0;border:1px solid rgba(92,134,7,.12);}
.edu-hero-inner{flex:1.3;}
.edu-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(92,134,7,.1);color:var(--brand);padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:16px;}
.edu-hero-title{font-size:2.4rem;font-weight:900;color:var(--brand-dark);margin:0 0 10px;line-height:1.2;}
.edu-hero-subtitle{font-size:1.1rem;color:#555;font-weight:500;margin:0 0 24px;line-height:1.8;}
.edu-hero-nav{display:flex;gap:10px;flex-wrap:wrap;}
.edu-hero-chip{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;border-radius:50px;font-weight:700;font-size:.9rem;text-decoration:none;background:#fff;color:var(--brand);border:2px solid rgba(92,134,7,.2);transition:all .3s;}
.edu-hero-chip:hover{background:var(--brand);color:#fff;border-color:var(--brand);transform:translateY(-2px);}
.edu-hero-deco{flex:.7;display:flex;flex-direction:column;gap:14px;}
.edu-hero-stat{background:#fff;padding:18px 24px;border-radius:14px;box-shadow:var(--shadow);display:flex;align-items:baseline;gap:12px;}
.edu-hero-stat-num{font-size:1.6rem;font-weight:900;color:var(--brand);}
.edu-hero-stat-label{font-size:.9rem;color:var(--text-secondary);}

/* === 通用區塊 === */
.edu-sections{margin-top:24px;}
.edu-sec-card{background:#fff;border-radius:var(--radius);padding:36px;box-shadow:var(--shadow);border:1px solid #eef2f7;}
.edu-sec-slim{padding:28px 36px;}
.edu-sec-header{display:flex;gap:16px;align-items:flex-start;margin-bottom:28px;padding-bottom:20px;border-bottom:2px solid var(--brand-light);}
.edu-sec-icon{width:52px;height:52px;border-radius:14px;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.edu-sec-header h2{font-size:1.5rem;font-weight:800;color:var(--brand-dark);margin:0 0 4px;}
.edu-sec-header p{font-size:1rem;color:#555;margin:0;line-height:1.6;}

/* === 篩選列 === */
.edu-filter-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid #f0f0f0;}
.edu-filter-btn{padding:8px 18px;border-radius:50px;border:1px solid #e2e8f0;background:#f8fafc;font-size:.88rem;font-weight:600;color:var(--text-secondary);cursor:pointer;transition:all .3s;font-family:inherit;}
.edu-filter-btn:hover{border-color:var(--brand);color:var(--brand);}
.edu-filter-btn.is-active{background:var(--brand);color:#fff;border-color:var(--brand);}

/* === 影片網格 === */
.edu-video-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.edu-video-card{border-radius:14px;overflow:hidden;border:1px solid #e2e8f0;transition:all .3s;display:flex;flex-direction:column;}
.edu-video-card.is-hidden{display:none;}
.edu-video-card:hover{transform:translateY(-5px);box-shadow:0 12px 28px rgba(0,0,0,.1);}
.edu-video-thumb{position:relative;height:180px;overflow:hidden;background:#111;}
.edu-video-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s;opacity:.9;}
.edu-video-card:hover .edu-video-thumb img{transform:scale(1.08);opacity:1;}
.edu-video-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(.8);width:52px;height:52px;background:rgba(0,0,0,.6);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;opacity:0;transition:all .3s;padding-left:3px;}
.edu-video-card:hover .edu-video-play{opacity:1;transform:translate(-50%,-50%) scale(1);}
.edu-video-duration{position:absolute;bottom:10px;right:10px;background:rgba(0,0,0,.75);color:#fff;padding:3px 10px;border-radius:4px;font-size:.75rem;font-weight:600;display:flex;align-items:center;gap:4px;}
.edu-video-info{padding:18px;flex-grow:1;display:flex;flex-direction:column;}
.edu-video-tags{display:flex;gap:6px;margin-bottom:10px;}
.edu-tag-topic{font-size:.75rem;font-weight:700;padding:3px 10px;border-radius:12px;background:var(--brand-light);color:var(--brand);}
.edu-tag-diff{font-size:.72rem;font-weight:700;padding:3px 10px;border-radius:12px;}
.edu-diff-beginner{background:#dbeafe;color:#1d4ed8;}
.edu-diff-intermediate{background:#fef3c7;color:#92400e;}
.edu-diff-advanced{background:#fce7f3;color:#be185d;}
.edu-video-title{font-size:1.05rem;font-weight:700;margin:0 0 8px;line-height:1.4;color:#222;transition:color .3s;}
.edu-video-card:hover .edu-video-title{color:var(--brand);}
.edu-video-desc{font-size:.92rem;color:#555;line-height:1.6;margin:0 0 14px;flex-grow:1;}
.edu-video-link{font-size:.9rem;font-weight:700;color:var(--brand);text-decoration:none;display:flex;align-items:center;gap:6px;transition:.2s;}
.edu-video-card:hover .edu-video-link{color:var(--brand-dark);text-decoration:underline;}

/* === 工作坊清單 === */
.edu-ws-list{display:flex;flex-direction:column;gap:16px;}
.edu-ws-item{display:flex;gap:20px;padding:24px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;transition:all .3s;align-items:flex-start;}
.edu-ws-item:hover{border-color:var(--brand);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.edu-ws-date-box{min-width:72px;text-align:center;background:var(--brand);color:#fff;border-radius:12px;padding:12px 8px;flex-shrink:0;display:flex;flex-direction:column;line-height:1;}
.edu-ws-month{font-size:.75rem;font-weight:600;opacity:.8;}
.edu-ws-day{font-size:1.8rem;font-weight:900;margin:2px 0;}
.edu-ws-weekday{font-size:.8rem;font-weight:600;opacity:.8;}
.edu-ws-content{flex-grow:1;}
.edu-ws-meta{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.edu-ws-status{font-size:.78rem;font-weight:700;padding:3px 10px;border-radius:12px;display:flex;align-items:center;gap:4px;}
.edu-ws-open{background:#dcfce7;color:#15803d;}
.edu-ws-open i{font-size:6px;animation:pulse-dot 1.5s infinite;}
@keyframes pulse-dot{0%,100%{opacity:1;}50%{opacity:.3;}}
.edu-ws-closed{background:#f3f4f6;color:#888;}
.edu-ws-full{background:#fef3c7;color:#92400e;}
.edu-ws-category{font-size:.8rem;font-weight:600;color:var(--text-secondary);padding:3px 10px;background:#fff;border-radius:12px;border:1px solid #e2e8f0;}
.edu-ws-title{font-size:1.15rem;font-weight:800;margin:0 0 10px;color:var(--brand-dark);}
.edu-ws-details{display:flex;flex-wrap:wrap;gap:14px;font-size:.9rem;color:#555;margin-bottom:10px;}
.edu-ws-details span{display:flex;align-items:center;gap:4px;}
.edu-ws-details i{color:var(--brand);font-size:.8rem;}
.edu-ws-desc{font-size:.95rem;color:#555;line-height:1.7;margin:0;}
.edu-ws-action{flex-shrink:0;align-self:center;}
.edu-ws-register{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;border-radius:50px;background:var(--brand);color:#fff;font-weight:700;font-size:.93rem;text-decoration:none;transition:all .3s;box-shadow:0 4px 12px rgba(92,134,7,.25);}
.edu-ws-register:hover{background:var(--brand-hover);transform:translateY(-2px);}
.edu-ws-ended{font-size:.88rem;color:#888;font-weight:600;}

/* === 下載資源 === */
.edu-dl-grid{display:flex;flex-direction:column;gap:12px;}
.edu-dl-card{display:flex;align-items:center;gap:16px;padding:18px 24px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);transition:all .3s;}
.edu-dl-card:hover{border-color:var(--brand);transform:translateX(5px);box-shadow:0 4px 12px rgba(0,0,0,.06);}
.edu-dl-icon{width:44px;height:44px;border-radius:10px;background:rgba(198,40,40,.08);color:#c62828;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.edu-dl-info{flex-grow:1;}
.edu-dl-info h4{font-size:1rem;font-weight:700;margin:0 0 2px;color:var(--brand-dark);}
.edu-dl-meta{font-size:.82rem;color:var(--text-secondary);}
.edu-dl-arrow{font-size:1rem;color:var(--brand);transition:transform .3s;}
.edu-dl-card:hover .edu-dl-arrow{transform:translateY(3px);}

/* === 交叉連結 === */
.edu-cross-title{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.edu-cross-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.edu-cross-card{display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;padding:20px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);transition:all .3s;}
.edu-cross-card:hover{border-color:var(--brand);transform:translateY(-3px);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.edu-cross-card i{font-size:24px;color:var(--brand);}
.edu-cross-card span{font-weight:700;font-size:.95rem;}
.edu-cross-card small{font-size:.78rem;color:var(--text-secondary);}

/* === RWD === */
@media(max-width:768px){
  .edu-hero{flex-direction:column;padding:28px 20px;gap:24px;}
  .edu-hero-title{font-size:1.8rem;}
  .edu-hero-deco{flex-direction:row;flex-wrap:wrap;gap:10px;}
  .edu-hero-stat{flex:1;min-width:130px;padding:14px 16px;}
  .edu-sec-card{padding:20px;}.edu-sec-header{flex-direction:column;gap:10px;}
  .edu-video-grid{grid-template-columns:1fr;}
  .edu-ws-item{flex-direction:column;}.edu-ws-date-box{flex-direction:row;min-width:auto;gap:8px;padding:10px 16px;align-items:center;}
  .edu-ws-day{font-size:1.2rem;margin:0;}.edu-ws-action{align-self:flex-start;}
  .edu-cross-grid{grid-template-columns:1fr 1fr;}
  .edu-filter-bar{gap:6px;}.edu-filter-btn{padding:6px 14px;font-size:.82rem;}
}
</style>

<!-- ========== JavaScript ========== -->
<script>
document.addEventListener('DOMContentLoaded',function(){
  /* 影片篩選 */
  var filterBtns=document.querySelectorAll('.edu-filter-btn');
  var cards=document.querySelectorAll('.edu-video-card');
  filterBtns.forEach(function(btn){
    btn.addEventListener('click',function(){
      filterBtns.forEach(function(b){b.classList.remove('is-active');});
      btn.classList.add('is-active');
      var filter=btn.getAttribute('data-filter');
      cards.forEach(function(card){
        if(filter==='all'||card.getAttribute('data-topic')===filter){
          card.classList.remove('is-hidden');
        }else{
          card.classList.add('is-hidden');
        }
      });
    });
  });
  /* 平滑捲動 */
  document.querySelectorAll('a[href^="#edu-"]').forEach(function(a){
    a.addEventListener('click',function(e){var t=document.querySelector(this.getAttribute('href'));if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}});
  });
});
</script>
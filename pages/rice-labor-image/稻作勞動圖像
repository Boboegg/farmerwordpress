<!-- ========== CSS ========== -->
<style>
/* === 全域變數 === */
.rli-hero,.rli-sections{
  --brand:#5C8607;--brand-dark:#4a6b05;--brand-light:#eef5ea;--brand-hover:#3d5a04;
  --accent:#D4A017;--text-primary:#1f2937;--text-secondary:#6b7280;
  --radius:16px;--shadow:0 4px 16px rgba(0,0,0,.06);
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);box-sizing:border-box;
}
.rli-hero *,.rli-sections *{box-sizing:border-box;}

/* === Hero === */
.rli-hero{display:flex;gap:40px;align-items:center;padding:48px 40px;background:linear-gradient(135deg,var(--brand-light) 0%,#fff 60%,#f0f4e8 100%);border-radius:var(--radius);margin-bottom:0;border:1px solid rgba(92,134,7,.12);}
.rli-hero-inner{flex:1.3;}
.rli-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(92,134,7,.1);color:var(--brand);padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:16px;}
.rli-hero-title{font-size:2.4rem;font-weight:900;color:var(--brand-dark);margin:0 0 10px;line-height:1.2;}
.rli-hero-subtitle{font-size:1.05rem;color:var(--text-secondary);font-weight:500;margin:0 0 24px;line-height:1.7;}
.rli-hero-nav{display:flex;gap:10px;flex-wrap:wrap;}
.rli-hero-chip{display:inline-flex;align-items:center;gap:6px;padding:10px 20px;border-radius:50px;font-weight:700;font-size:.9rem;text-decoration:none;background:#fff;color:var(--brand);border:2px solid rgba(92,134,7,.2);transition:all .3s;}
.rli-hero-chip:hover{background:var(--brand);color:#fff;border-color:var(--brand);transform:translateY(-2px);}
.rli-hero-deco{flex:.7;display:flex;flex-direction:column;gap:14px;}
.rli-hero-stat{background:#fff;padding:18px 24px;border-radius:14px;box-shadow:var(--shadow);display:flex;align-items:center;gap:12px;}
.rli-hero-stat-num{font-size:1.4rem;color:var(--brand);}
.rli-hero-stat-label{font-size:.9rem;color:var(--text-secondary);font-weight:600;}

/* === 通用區塊 === */
.rli-sections{margin-top:24px;}
.rli-sec-card{background:#fff;border-radius:var(--radius);padding:36px;box-shadow:var(--shadow);border:1px solid #eef2f7;}
.rli-sec-slim{padding:28px 36px;}
.rli-sec-header{display:flex;gap:16px;align-items:flex-start;margin-bottom:28px;padding-bottom:20px;border-bottom:2px solid var(--brand-light);}
.rli-sec-icon{width:52px;height:52px;border-radius:14px;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.rli-sec-header h2{font-size:1.5rem;font-weight:800;color:var(--brand-dark);margin:0 0 4px;}
.rli-sec-header p{font-size:.95rem;color:var(--text-secondary);margin:0;line-height:1.5;}
.rli-sec-lead{font-size:.98rem;color:var(--text-secondary);line-height:1.8;margin:0 0 24px;padding:16px 20px;background:var(--brand-light);border-radius:12px;border-left:4px solid var(--brand);}

/* === 調查說明 === */
.rli-intro-text{margin-bottom:24px;}
.rli-intro-text p{font-size:.98rem;color:var(--text-primary);line-height:1.8;margin:0 0 12px;}
.rli-scope-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.rli-scope-card{text-align:center;padding:24px 16px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;transition:all .3s;}
.rli-scope-card:hover{border-color:var(--brand);transform:translateY(-3px);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.rli-scope-icon{font-size:28px;color:var(--brand);margin-bottom:12px;}
.rli-scope-card h4{font-size:1rem;font-weight:700;color:var(--brand-dark);margin:0 0 6px;}
.rli-scope-card p{font-size:.88rem;color:var(--text-secondary);margin:0;line-height:1.5;}

/* === 種植技術 — 階段時間軸 === */
.rli-phase-timeline{display:flex;flex-direction:column;gap:20px;}
.rli-phase-card{display:flex;gap:20px;padding:24px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;transition:all .3s;}
.rli-phase-card:hover{border-color:var(--brand);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.rli-phase-num{min-width:52px;height:52px;background:var(--brand);color:#fff;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:900;flex-shrink:0;font-family:"Lato",sans-serif;}
.rli-phase-content{flex-grow:1;}
.rli-phase-content h3{font-size:1.15rem;font-weight:800;color:var(--brand-dark);margin:0 0 14px;display:flex;align-items:center;gap:8px;}
.rli-phase-content h3 i{color:var(--brand);font-size:1rem;}
.rli-obs-list{display:flex;flex-direction:column;gap:10px;}
.rli-obs-card{padding:14px 18px;background:#fff;border-radius:10px;border:1px solid #e2e8f0;}
.rli-obs-label{display:inline-block;font-size:.75rem;font-weight:700;padding:2px 10px;border-radius:8px;background:var(--brand-light);color:var(--brand);margin-bottom:6px;}
.rli-obs-card p{font-size:.9rem;color:var(--text-secondary);line-height:1.6;margin:0;}

/* === 勞動過程 — 卡片網格 === */
.rli-labor-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;}
.rli-labor-card{padding:28px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;transition:all .3s;}
.rli-labor-card:hover{border-color:var(--brand);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.rli-labor-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:14px;}
.rli-labor-card h3{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 12px;}
.rli-labor-points{margin:0 0 14px;padding-left:20px;list-style:none;}
.rli-labor-points li{position:relative;font-size:.9rem;color:var(--text-secondary);line-height:1.6;padding:4px 0 4px 16px;}
.rli-labor-points li::before{content:"";position:absolute;left:0;top:12px;width:6px;height:6px;border-radius:50%;background:var(--brand);}

/* === 人際關係 — 卡片網格 === */
.rli-rel-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;}
.rli-rel-card{padding:28px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;transition:all .3s;}
.rli-rel-card:hover{border-color:var(--brand);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.rli-rel-icon{width:48px;height:48px;border-radius:12px;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:14px;}
.rli-rel-card h3{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 10px;}
.rli-rel-card>p{font-size:.9rem;color:var(--text-secondary);line-height:1.7;margin:0 0 14px;}

/* === 交叉連結 === */
.rli-cross-title{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.rli-cross-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.rli-cross-card{display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;padding:20px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);transition:all .3s;}
.rli-cross-card:hover{border-color:var(--brand);transform:translateY(-3px);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.rli-cross-card i{font-size:24px;color:var(--brand);}
.rli-cross-card span{font-weight:700;font-size:.95rem;}
.rli-cross-card small{font-size:.78rem;color:var(--text-secondary);}

/* === RWD === */
@media(max-width:768px){
  .rli-hero{flex-direction:column;padding:28px 20px;gap:24px;}
  .rli-hero-title{font-size:1.8rem;}
  .rli-hero-deco{flex-direction:row;flex-wrap:wrap;gap:10px;}
  .rli-hero-stat{flex:1;min-width:130px;padding:14px 16px;}
  .rli-sec-card{padding:20px;}.rli-sec-header{flex-direction:column;gap:10px;}
  .rli-scope-grid{grid-template-columns:1fr 1fr;}
  .rli-phase-card{flex-direction:column;gap:12px;}
  .rli-phase-num{min-width:auto;width:44px;height:44px;font-size:.95rem;}
  .rli-labor-grid{grid-template-columns:1fr;}
  .rli-rel-grid{grid-template-columns:1fr;}
  .rli-cross-grid{grid-template-columns:1fr 1fr;}
}
</style>

<!-- ========== JavaScript ========== -->
<script>
document.addEventListener('DOMContentLoaded',function(){
  /* 平滑捲動 */
  document.querySelectorAll('a[href^="#rli-"]').forEach(function(a){
    a.addEventListener('click',function(e){
      var t=document.querySelector(this.getAttribute('href'));
      if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}
    });
  });
});
</script>

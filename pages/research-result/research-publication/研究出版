<!-- =====================================================
     子頁：研究成果 / 研究出版
     URL：/research-result/research-publication/
     WordPress 頁面 → 程式碼編輯器 → 全選貼入
     CSS 前綴：res-（與主頁共用）
     
     【維護指南】
     - 報告條目：複製 .res-bib-item 區塊新增
     - 篩選：data-category 對應 filter 按鈕
     - CSS 已內含，不需依賴主頁
     ===================================================== -->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&family=Lato:wght@400;700;900&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<!-- Hero -->
<div class="res-hero" style="padding:36px 40px;">
  <div class="res-hero-inner">
    <div class="res-hero-badge" style="background:rgba(124,58,237,.1);color:#7c3aed;"><i class="fas fa-book-open"></i> Publications</div>
    <h1 class="res-hero-title" style="font-size:2rem;">研究出版</h1>
    <p class="res-hero-subtitle">⚠️ 一句話說明，例如：期刊論文、計畫報告、學位論文、政策白皮書等學術產出。</p>
    <a href="/research-result/" class="res-back-link"><i class="fas fa-arrow-left"></i> 回到研究成果總覽</a>
  </div>
</div>

<!-- 子頁導覽列 -->
<div class="res-sections" style="margin-top:16px;">
  <div class="res-sub-nav">
    <a href="/research-result/research-publication/" class="res-sub-nav-item is-current">研究出版</a>
    <a href="/research-result/podcast/" class="res-sub-nav-item">影音 Podcast</a>
    <a href="/research-result/infographic/" class="res-sub-nav-item">圖文資訊</a>
    <a href="/research-result/download-zone/" class="res-sub-nav-item">下載專區</a>
    <a href="/research-result/related-resources/" class="res-sub-nav-item">相關資源</a>
  </div>
</div>

<!-- 報告列表 -->
<div class="res-sections">
  <div class="res-sec-card">
    <div class="res-sec-header">
      <div class="res-sec-icon" style="background:rgba(124,58,237,.1);color:#7c3aed;"><i class="fas fa-book-open"></i></div>
      <div><h2>學術論文與計畫報告</h2><p>依年份排序，最新在前。每份文獻附 PDF 下載（如可取得）。</p></div>
    </div>

    <div class="res-filter-bar">
      <button class="res-filter-btn is-active" data-filter="all">全部</button>
      <button class="res-filter-btn" data-filter="annual">年度報告</button>
      <button class="res-filter-btn" data-filter="policy">政策白皮書</button>
      <button class="res-filter-btn" data-filter="needs">需求評估</button>
    </div>

    <div class="res-sec-body">
      <div class="res-bib-list">

        <!-- ===== 報告條目模板 ===== -->
        <div class="res-bib-item" data-category="annual">
          <div class="res-bib-num">1.</div>
          <div class="res-bib-body">
            <p class="res-bib-ref">⚠️ Author(s). (Year). <em>Title of report</em> (Report No. xxx). Publisher. URL</p>
            <p class="res-feat-abstract" style="font-size:.88rem;color:#6b7280;line-height:1.6;margin:8px 0 0;">⚠️ 報告摘要，3-4 行。說明報告涵蓋範圍、核心發現與政策建議方向。</p>
            <div class="res-bib-meta" style="margin-top:10px;">
              <span class="res-feat-tag">⚠️ 關鍵字</span>
              <span class="res-feat-tag">⚠️ 頁數：XX 頁</span>
            </div>
          </div>
          <div class="res-bib-actions">
            <a href="#" class="res-dl-btn"><i class="fas fa-file-pdf"></i> PDF<span class="res-dl-size">⚠️ MB</span></a>
          </div>
        </div>
        <!-- ===== 模板結束 ===== -->

        <div class="res-bib-item" data-category="policy">
          <div class="res-bib-num">2.</div>
          <div class="res-bib-body">
            <p class="res-bib-ref">⚠️ APA 引用。</p>
            <p class="res-feat-abstract" style="font-size:.88rem;color:#6b7280;line-height:1.6;margin:8px 0 0;">⚠️ 摘要。</p>
          </div>
          <div class="res-bib-actions"><a href="#" class="res-dl-btn"><i class="fas fa-file-pdf"></i> PDF<span class="res-dl-size">⚠️ MB</span></a></div>
        </div>

        <div class="res-bib-item" data-category="needs">
          <div class="res-bib-num">3.</div>
          <div class="res-bib-body">
            <p class="res-bib-ref">⚠️ APA 引用。</p>
            <p class="res-feat-abstract" style="font-size:.88rem;color:#6b7280;line-height:1.6;margin:8px 0 0;">⚠️ 摘要。</p>
          </div>
          <div class="res-bib-actions"><a href="#" class="res-dl-btn"><i class="fas fa-file-pdf"></i> PDF<span class="res-dl-size">⚠️ MB</span></a></div>
        </div>

        <!-- ⚠️ 繼續複製 .res-bib-item 新增 -->
      </div>
    </div>
  </div>
</div>

<!-- ========== CSS ========== -->
<style>
.res-hero,.res-sections{
  --brand:#5C8607;--brand-dark:#4a6b05;--brand-light:#eef5ea;
  --text-primary:#1f2937;--text-secondary:#6b7280;
  --radius:16px;--shadow:0 4px 16px rgba(0,0,0,.06);
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);box-sizing:border-box;
}
.res-hero *,.res-sections *{box-sizing:border-box;}
.res-hero{display:flex;gap:40px;align-items:flex-start;padding:48px 40px;background:linear-gradient(135deg,var(--brand-light) 0%,#fff 60%,#f0f4e8 100%);border-radius:var(--radius);margin-bottom:0;border:1px solid rgba(92,134,7,.12);}
.res-hero-inner{flex:1;}
.res-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(92,134,7,.1);color:var(--brand);padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:16px;letter-spacing:.5px;}
.res-hero-title{font-size:2.4rem;font-weight:900;color:var(--brand-dark);margin:0 0 10px;line-height:1.2;}
.res-hero-subtitle{font-size:1.05rem;color:var(--text-secondary);font-weight:500;margin:0 0 20px;line-height:1.7;}
.res-back-link{display:inline-flex;align-items:center;gap:6px;font-size:.9rem;color:var(--text-secondary);text-decoration:none;transition:.2s;margin-top:16px;}.res-back-link:hover{color:var(--brand);}
.res-sections{margin-top:24px;}
.res-sec-card{background:#fff;border-radius:var(--radius);padding:36px;box-shadow:var(--shadow);border:1px solid #eef2f7;}
.res-sec-header{display:flex;gap:16px;align-items:flex-start;margin-bottom:28px;padding-bottom:20px;border-bottom:2px solid var(--brand-light);}
.res-sec-icon{width:52px;height:52px;border-radius:14px;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.res-sec-header h2{font-size:1.5rem;font-weight:800;color:var(--brand-dark);margin:0 0 4px;}
.res-sec-header p{font-size:.95rem;color:var(--text-secondary);margin:0;line-height:1.5;}
.res-sub-nav{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:24px;}
.res-sub-nav-item{padding:8px 18px;border-radius:50px;font-size:.88rem;font-weight:600;text-decoration:none;border:1px solid #e2e8f0;color:var(--text-secondary);transition:all .3s;}
.res-sub-nav-item:hover{border-color:var(--brand);color:var(--brand);}
.res-sub-nav-item.is-current{background:var(--brand);color:#fff;border-color:var(--brand);}
.res-filter-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid #f0f0f0;}
.res-filter-btn{padding:8px 18px;border-radius:50px;border:1px solid #e2e8f0;background:#f8fafc;font-size:.88rem;font-weight:600;color:var(--text-secondary);cursor:pointer;transition:all .3s;font-family:inherit;}
.res-filter-btn:hover{border-color:var(--brand);color:var(--brand);}
.res-filter-btn.is-active{background:var(--brand);color:#fff;border-color:var(--brand);}
.res-bib-list{display:flex;flex-direction:column;gap:14px;}
.res-bib-item{display:flex;gap:16px;padding:20px 24px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;align-items:flex-start;transition:all .3s;}
.res-bib-item:hover{border-color:var(--brand);box-shadow:0 4px 14px rgba(0,0,0,.05);}
.res-bib-num{font-size:.82rem;font-weight:800;color:var(--brand);min-width:28px;flex-shrink:0;padding-top:2px;font-family:"Lato",sans-serif;}
.res-bib-body{flex-grow:1;}
.res-bib-ref{font-size:.95rem;line-height:1.7;font-family:"Lora","Noto Sans TC",serif;margin:0 0 6px;color:var(--text-primary);}
.res-bib-ref em{font-style:italic;}
.res-bib-meta{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
.res-bib-actions{flex-shrink:0;align-self:center;}
.res-feat-tag{font-size:.75rem;padding:2px 10px;border-radius:10px;background:#e2e8f0;color:var(--text-secondary);}
.res-dl-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:10px;font-weight:700;font-size:.88rem;text-decoration:none;transition:all .3s;white-space:nowrap;background:#fff;color:#c62828;border:1px solid #fca5a5;}.res-dl-btn:hover{background:#c62828;color:#fff;border-color:#c62828;transform:translateY(-2px);}
.res-dl-size{font-size:.72rem;font-weight:500;color:#999;margin-left:4px;}
.res-dl-btn:hover .res-dl-size{color:rgba(255,255,255,.7);}
@media(max-width:768px){
  .res-hero{flex-direction:column;padding:28px 20px;gap:24px;}
  .res-hero-title{font-size:1.8rem;}
  .res-sec-card{padding:20px;}.res-sec-header{flex-direction:column;gap:10px;}
  .res-sub-nav{gap:6px;}.res-sub-nav-item{padding:6px 14px;font-size:.82rem;}
  .res-bib-item{flex-direction:column;gap:8px;}.res-bib-actions{align-self:flex-start;}
}
</style>
<script>
document.addEventListener('DOMContentLoaded',function(){
  document.querySelectorAll('.res-filter-btn').forEach(function(btn){
    btn.addEventListener('click',function(){
      var bar=btn.closest('.res-filter-bar');
      bar.querySelectorAll('.res-filter-btn').forEach(function(b){b.classList.remove('is-active');});
      btn.classList.add('is-active');
      var filter=btn.getAttribute('data-filter');
      var container=bar.nextElementSibling;
      if(!container)return;
      var items=container.querySelectorAll('[data-category]');
      items.forEach(function(item){
        if(filter==='all'||item.getAttribute('data-category')===filter){item.style.display='';}
        else{item.style.display='none';}
      });
    });
  });
});
</script>
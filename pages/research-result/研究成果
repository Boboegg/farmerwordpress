</div>

<!-- ========== CSS（主頁 + 子頁共用）========== -->
<style>
/* === 變數 === */
.res-hero,.res-sections{
  --brand:#5C8607;--brand-dark:#4a6b05;--brand-light:#eef5ea;--brand-hover:#3d5a04;
  --accent:#D4A017;--text-primary:#1f2937;--text-secondary:#555;
  --radius:16px;--shadow:0 4px 16px rgba(0,0,0,.06);
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);box-sizing:border-box;
}
.res-hero *,.res-sections *{box-sizing:border-box;}

/* === Hero === */
.res-hero{display:flex;gap:40px;align-items:flex-start;padding:48px 40px;background:linear-gradient(135deg,var(--brand-light) 0%,#fff 60%,#f0f4e8 100%);border-radius:var(--radius);margin-bottom:0;border:1px solid rgba(92,134,7,.12);}
.res-hero-inner{flex:1.3;}
.res-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(92,134,7,.1);color:var(--brand);padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:16px;letter-spacing:.5px;}
.res-hero-title{font-size:2.4rem;font-weight:900;color:var(--brand-dark);margin:0 0 10px;line-height:1.2;}
.res-hero-subtitle{font-size:1.05rem;color:var(--text-secondary);font-weight:500;margin:0 0 20px;line-height:1.7;}
.res-hero-note{display:flex;align-items:flex-start;gap:10px;background:rgba(255,255,255,.7);border-radius:12px;padding:16px 20px;border:1px solid rgba(92,134,7,.1);font-size:.9rem;line-height:1.6;color:var(--text-secondary);}
.res-hero-note i{color:var(--brand);margin-top:3px;flex-shrink:0;}
.res-hero-deco{flex:.7;display:flex;flex-direction:column;gap:14px;position:sticky;top:20px;}
.res-hero-stat{background:#fff;padding:18px 24px;border-radius:14px;box-shadow:var(--shadow);display:flex;align-items:baseline;gap:12px;}
.res-hero-stat-num{font-size:1.6rem;font-weight:900;color:var(--brand);font-family:"Lato",sans-serif;}
.res-hero-stat-label{font-size:.9rem;color:var(--text-secondary);}

/* === 通用區塊 === */
.res-sections{margin-top:24px;}
.res-sec-card{background:#fff;border-radius:var(--radius);padding:36px;box-shadow:var(--shadow);border:1px solid #eef2f7;}
.res-sec-slim{padding:28px 36px;}
.res-sec-header{display:flex;gap:16px;align-items:flex-start;margin-bottom:28px;padding-bottom:20px;border-bottom:2px solid var(--brand-light);}
.res-sec-icon{width:52px;height:52px;border-radius:14px;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.res-sec-header h2{font-size:1.5rem;font-weight:800;color:var(--brand-dark);margin:0 0 4px;}
.res-sec-header p{font-size:.95rem;color:var(--text-secondary);margin:0;line-height:1.5;}

/* === 五大分類卡 === */
.res-cat-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:18px;}
.res-cat-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:28px 16px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);transition:all .3s;position:relative;}
.res-cat-card:hover{transform:translateY(-5px);box-shadow:0 12px 28px rgba(0,0,0,.1);border-color:var(--brand);}
.res-cat-icon{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:14px;}
.res-cat-card h3{font-size:1rem;font-weight:800;color:var(--brand-dark);margin:0 0 6px;}
.res-cat-card p{font-size:.82rem;color:var(--text-secondary);line-height:1.4;margin:0 0 10px;}
.res-cat-count{font-size:.78rem;font-weight:700;padding:3px 12px;border-radius:12px;background:var(--brand-light);color:var(--brand);}

/* === 精選成果列表 === */
.res-feat-list{display:flex;flex-direction:column;gap:16px;}
.res-feat-card{display:flex;gap:20px;padding:24px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;align-items:flex-start;transition:all .3s;}
.res-feat-card:hover{border-color:var(--brand);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.res-feat-type{writing-mode:vertical-rl;text-orientation:mixed;font-size:.78rem;font-weight:800;padding:8px 6px;border-radius:8px;display:flex;align-items:center;gap:6px;flex-shrink:0;letter-spacing:1px;}
.res-type-journal{background:rgba(21,101,192,.1);color:#1565c0;}
.res-type-report{background:rgba(124,58,237,.1);color:#7c3aed;}
.res-type-conf{background:rgba(13,148,136,.1);color:#0d9488;}
.res-type-podcast{background:rgba(198,40,40,.1);color:#c62828;}
.res-type-infographic{background:rgba(245,158,11,.1);color:#d97706;}
.res-feat-content{flex-grow:1;}
.res-feat-content h3{font-size:1rem;font-weight:600;color:var(--text-primary);margin:0 0 8px;line-height:1.6;font-family:"Lora","Noto Sans TC",serif;}
.res-feat-content h3 em{font-style:italic;}
.res-feat-abstract{font-size:.88rem;color:var(--text-secondary);line-height:1.6;margin:0 0 10px;}
.res-feat-tags{display:flex;flex-wrap:wrap;gap:6px;}
.res-feat-tag{font-size:.75rem;padding:2px 10px;border-radius:10px;background:#e2e8f0;color:var(--text-secondary);}
.res-feat-actions{flex-shrink:0;align-self:center;display:flex;flex-direction:column;gap:8px;}
.res-dl-btn,.res-play-btn{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:10px;font-weight:700;font-size:.88rem;text-decoration:none;transition:all .3s;white-space:nowrap;}
.res-dl-btn{background:#fff;color:#c62828;border:1px solid #fca5a5;}.res-dl-btn:hover{background:#c62828;color:#fff;border-color:#c62828;transform:translateY(-2px);}
.res-dl-size{font-size:.72rem;font-weight:500;color:#888;margin-left:4px;}
.res-dl-btn:hover .res-dl-size{color:rgba(255,255,255,.7);}
.res-play-btn{background:var(--brand-light);color:var(--brand);border:1px solid rgba(92,134,7,.2);}.res-play-btn:hover{background:var(--brand);color:#fff;transform:translateY(-2px);}

/* === 交叉連結 === */
.res-cross-title{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.res-cross-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.res-cross-card{display:flex;flex-direction:column;align-items:center;text-align:center;gap:8px;padding:20px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);transition:all .3s;}
.res-cross-card:hover{border-color:var(--brand);transform:translateY(-3px);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.res-cross-card i{font-size:24px;color:var(--brand);}
.res-cross-card span{font-weight:700;font-size:.95rem;}

/* === 子頁共用：返回連結 === */
.res-back-link{display:inline-flex;align-items:center;gap:6px;font-size:.9rem;color:var(--text-secondary);text-decoration:none;transition:.2s;margin-top:16px;}.res-back-link:hover{color:var(--brand);}

/* === 子頁共用：篩選列 === */
.res-filter-bar{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid #f0f0f0;}
.res-filter-btn{padding:8px 18px;border-radius:50px;border:1px solid #e2e8f0;background:#f8fafc;font-size:.88rem;font-weight:600;color:var(--text-secondary);cursor:pointer;transition:all .3s;font-family:inherit;}
.res-filter-btn:hover{border-color:var(--brand);color:var(--brand);}
.res-filter-btn.is-active{background:var(--brand);color:#fff;border-color:var(--brand);}

/* === 子頁共用：APA 文獻清單 === */
.res-bib-list{display:flex;flex-direction:column;gap:14px;}
.res-bib-item{display:flex;gap:16px;padding:20px 24px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;align-items:flex-start;transition:all .3s;}
.res-bib-item:hover{border-color:var(--brand);box-shadow:0 4px 14px rgba(0,0,0,.05);}
.res-bib-num{font-size:.82rem;font-weight:800;color:var(--brand);min-width:28px;flex-shrink:0;padding-top:2px;font-family:"Lato",sans-serif;}
.res-bib-body{flex-grow:1;}
.res-bib-ref{font-size:.95rem;line-height:1.7;font-family:"Lora","Noto Sans TC",serif;margin:0 0 6px;color:var(--text-primary);}
.res-bib-ref em{font-style:italic;}
.res-bib-meta{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px;}
.res-bib-actions{flex-shrink:0;align-self:center;}

/* === 子頁共用：媒體嵌入區 === */
.res-embed-card{background:#f8fafc;border-radius:14px;padding:24px;border:1px solid #e2e8f0;margin-bottom:16px;}
.res-embed-card h3{font-size:1.05rem;font-weight:800;color:var(--brand-dark);margin:0 0 6px;}
.res-embed-meta{font-size:.85rem;color:var(--text-secondary);margin-bottom:14px;}
.res-embed-player{width:100%;border-radius:10px;overflow:hidden;margin-bottom:10px;}
.res-embed-player iframe{width:100%;border:none;}
.res-embed-desc{font-size:.9rem;color:var(--text-secondary);line-height:1.6;margin:0;}

/* === 子頁共用：圖表畫廊 === */
.res-gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.res-gallery-card{border-radius:14px;overflow:hidden;border:1px solid #e2e8f0;transition:all .3s;text-decoration:none;color:var(--text-primary);}
.res-gallery-card:hover{transform:translateY(-5px);box-shadow:0 12px 28px rgba(0,0,0,.1);}
.res-gallery-thumb{height:200px;overflow:hidden;background:#f0f0f0;}
.res-gallery-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s;}
.res-gallery-card:hover .res-gallery-thumb img{transform:scale(1.05);}
.res-gallery-info{padding:18px;}
.res-gallery-info h4{font-size:1rem;font-weight:700;margin:0 0 6px;color:var(--brand-dark);}
.res-gallery-info p{font-size:.85rem;color:var(--text-secondary);margin:0 0 10px;line-height:1.5;}
.res-gallery-dl{font-size:.85rem;font-weight:700;color:var(--brand);display:flex;align-items:center;gap:4px;}

/* === 子頁共用：下載清單 === */
.res-dl-list{display:flex;flex-direction:column;gap:14px;}
.res-dl-item{display:flex;gap:16px;padding:20px 24px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;align-items:center;transition:all .3s;}
.res-dl-item:hover{border-color:var(--brand);box-shadow:0 4px 14px rgba(0,0,0,.05);}
.res-dl-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.res-dl-icon-pdf{background:rgba(198,40,40,.1);color:#c62828;}
.res-dl-icon-ppt{background:rgba(245,158,11,.1);color:#d97706;}
.res-dl-icon-doc{background:rgba(21,101,192,.1);color:#1565c0;}
.res-dl-icon-zip{background:rgba(124,58,237,.1);color:#7c3aed;}
.res-dl-item-body{flex-grow:1;}
.res-dl-item-title{font-size:1rem;font-weight:700;color:var(--text-primary);margin:0 0 4px;}
.res-dl-item-desc{font-size:.85rem;color:var(--text-secondary);margin:0;line-height:1.5;}

/* === 子頁共用：資源連結卡 === */
.res-link-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;}
.res-link-card{display:flex;gap:16px;padding:20px 24px;background:#f8fafc;border-radius:14px;border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);align-items:flex-start;transition:all .3s;}
.res-link-card:hover{border-color:var(--brand);box-shadow:0 6px 18px rgba(0,0,0,.06);transform:translateY(-3px);}
.res-link-icon{width:48px;height:48px;border-radius:12px;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.res-link-body{flex-grow:1;}
.res-link-body h4{font-size:1rem;font-weight:700;color:var(--brand-dark);margin:0 0 4px;}
.res-link-body p{font-size:.85rem;color:var(--text-secondary);margin:0;line-height:1.5;}
.res-link-arrow{color:var(--brand);align-self:center;font-size:16px;opacity:.4;transition:.3s;}
.res-link-card:hover .res-link-arrow{opacity:1;transform:translateX(4px);}


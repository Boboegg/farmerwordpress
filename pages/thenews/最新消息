<!-- =====================================================
     頁面：最新消息
     URL：/thenews/
     WordPress 頁面 → 程式碼編輯器 → 全選貼入
     CSS 前綴：tnews-
     主色系：#5C8607（品牌尊嚴綠）

     【維護指南】
     - 本頁使用 [my_newss_loop] 短碼自動撈取文章
     - 分類 Tab 可自行增減，複製 .tnews-tab 按鈕即可
     - 每個 .tnews-tab-panel 內放對應的 shortcode
     - 新增分類時請同步更新 docs/article-category-slugs.md
     ===================================================== -->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&family=Lato:wght@400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<!-- ========== 區塊 1：Hero ========== -->
<div class="tnews-hero">
  <div class="tnews-hero-inner">
    <div class="tnews-hero-badge"><i class="fas fa-newspaper"></i> News & Updates</div>
    <h1 class="tnews-hero-title">最新消息</h1>
    <p class="tnews-hero-subtitle">掌握計畫動態、活動快訊、媒體報導與各領域最新文章，一站瀏覽所有更新。</p>
  </div>
  <div class="tnews-hero-deco">
    <div class="tnews-hero-icon"><i class="fas fa-bell"></i></div>
    <div class="tnews-hero-icon"><i class="fas fa-bullhorn"></i></div>
    <div class="tnews-hero-icon"><i class="fas fa-rss"></i></div>
  </div>
</div>

<!-- ========== 區塊 2：分類標籤列 ========== -->
<div class="tnews-wrapper" id="tnews-app">

  <div class="tnews-tab-bar">
    <button class="tnews-tab is-active" data-tab="all">
      <i class="fas fa-layer-group"></i> 全部
    </button>
    <button class="tnews-tab" data-tab="news">
      <i class="fas fa-newspaper"></i> 最新消息
    </button>
    <button class="tnews-tab" data-tab="event">
      <i class="fas fa-calendar-check"></i> 活動快訊
    </button>
    <button class="tnews-tab" data-tab="press">
      <i class="fas fa-tv"></i> 媒體報導
    </button>
    <button class="tnews-tab" data-tab="notices">
      <i class="fas fa-circle-info"></i> 網站公告
    </button>
    <button class="tnews-tab" data-tab="podcast">
      <i class="fas fa-podcast"></i> Podcast
    </button>
    <button class="tnews-tab" data-tab="youtube">
      <i class="fab fa-youtube"></i> YouTube
    </button>
    <button class="tnews-tab" data-tab="agri-school">
      <i class="fas fa-seedling"></i> 農學堂
    </button>
    <button class="tnews-tab" data-tab="health">
      <i class="fas fa-heart-pulse"></i> 職業健康
    </button>
    <button class="tnews-tab" data-tab="equipment">
      <i class="fas fa-helmet-safety"></i> 安全裝備
    </button>
    <button class="tnews-tab" data-tab="insurance">
      <i class="fas fa-shield-halved"></i> 經濟保險
    </button>
    <button class="tnews-tab" data-tab="research">
      <i class="fas fa-flask"></i> 研究出版
    </button>
  </div>

  <!-- ========== 區塊 3：各分類內容面板 ========== -->

  <!-- 全部（預設顯示）-->
  <div class="tnews-tab-panel is-visible" data-panel="all">
    [my_newss_loop count="12" title=""]
  </div>

  <!-- 最新消息 -->
  <div class="tnews-tab-panel" data-panel="news">
    [my_newss_loop cat="news" count="12" title=""]
  </div>

  <!-- 活動快訊 -->
  <div class="tnews-tab-panel" data-panel="event">
    [my_newss_loop cat="event" count="12" title=""]
  </div>

  <!-- 媒體報導 -->
  <div class="tnews-tab-panel" data-panel="press">
    [my_newss_loop cat="press" count="12" title=""]
  </div>

  <!-- 網站公告 -->
  <div class="tnews-tab-panel" data-panel="notices">
    [my_newss_loop cat="notices" count="12" title=""]
  </div>

  <!-- Podcast -->
  <div class="tnews-tab-panel" data-panel="podcast">
    [my_newss_loop cat="podcast" count="12" title=""]
  </div>

  <!-- YouTube -->
  <div class="tnews-tab-panel" data-panel="youtube">
    [my_newss_loop cat="youtube" count="12" title=""]
  </div>

  <!-- 農學堂 -->
  <div class="tnews-tab-panel" data-panel="agri-school">
    [my_newss_loop cat="agri-school" count="12" title=""]
  </div>

  <!-- 職業健康 -->
  <div class="tnews-tab-panel" data-panel="health">
    [my_newss_loop cat="health" count="12" title=""]
  </div>

  <!-- 安全裝備 -->
  <div class="tnews-tab-panel" data-panel="equipment">
    [my_newss_loop cat="equipment" count="12" title=""]
  </div>

  <!-- 經濟保險 -->
  <div class="tnews-tab-panel" data-panel="insurance">
    [my_newss_loop cat="insurance" count="12" title=""]
  </div>

  <!-- 研究出版 -->
  <div class="tnews-tab-panel" data-panel="research">
    [my_newss_loop cat="research" count="12" title=""]
  </div>

</div>

<!-- ========== 區塊 4：延伸探索 ========== -->
<div class="tnews-explore">
  <h3 class="tnews-explore-title"><i class="fas fa-compass"></i> 延伸探索</h3>
  <div class="tnews-explore-grid">
    <a href="/research-result/podcast/" class="tnews-explore-card">
      <i class="fas fa-podcast"></i><span>Podcast 專區</span>
    </a>
    <a href="/research-result/" class="tnews-explore-card">
      <i class="fas fa-flask"></i><span>研究成果</span>

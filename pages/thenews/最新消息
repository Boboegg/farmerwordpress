<!-- ========== CSS ========== -->
<style>
/* === 變數 === */
.tnews-hero,.tnews-wrapper,.tnews-explore {
  --brand:#5C8607;--brand-dark:#4a6b05;--brand-light:#eef5ea;--brand-hover:#3d5a04;
  --accent:#D4A017;--text-primary:#1f2937;--text-secondary:#6b7280;
  --radius:16px;--shadow:0 4px 16px rgba(0,0,0,.06);
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);box-sizing:border-box;
}
.tnews-hero *,.tnews-wrapper *,.tnews-explore *{box-sizing:border-box;}

/* === Hero === */
.tnews-hero {
  display:flex;gap:40px;align-items:center;
  padding:48px 40px;
  background:linear-gradient(135deg,var(--brand-light) 0%,#fff 50%,#f8faf5 100%);
  border-radius:var(--radius);margin-bottom:0;
  border:1px solid rgba(92,134,7,.12);
  position:relative;overflow:hidden;
}
.tnews-hero::before {
  content:'';position:absolute;top:-60px;right:-60px;width:200px;height:200px;
  background:radial-gradient(circle,rgba(92,134,7,.08) 0%,transparent 70%);
  border-radius:50%;pointer-events:none;
}
.tnews-hero-inner{flex:1;}
.tnews-hero-badge {
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(92,134,7,.1);color:var(--brand);
  padding:6px 16px;border-radius:20px;
  font-size:.85rem;font-weight:700;margin-bottom:16px;letter-spacing:.5px;
}
.tnews-hero-title {
  font-size:2.4rem;font-weight:900;color:var(--brand-dark);
  margin:0 0 10px;line-height:1.2;
}
.tnews-hero-subtitle {
  font-size:1.05rem;color:var(--text-secondary);
  font-weight:500;margin:0;line-height:1.7;max-width:600px;
}
.tnews-hero-deco {
  display:flex;gap:16px;flex-shrink:0;
}
.tnews-hero-icon {
  width:64px;height:64px;border-radius:16px;
  background:#fff;box-shadow:var(--shadow);
  display:flex;align-items:center;justify-content:center;
  font-size:24px;color:var(--brand);
  transition:transform .3s;
}
.tnews-hero-icon:hover{transform:translateY(-4px);}
.tnews-hero-icon:nth-child(2){color:var(--accent);}
.tnews-hero-icon:nth-child(3){color:#c62828;}

/* === Tab Bar === */
.tnews-wrapper{margin-top:24px;}
.tnews-tab-bar {
  display:flex;flex-wrap:wrap;gap:8px;
  padding:20px 24px;
  background:#fff;border-radius:var(--radius) var(--radius) 0 0;
  box-shadow:var(--shadow);border:1px solid #eef2f7;border-bottom:none;
  position:sticky;top:0;z-index:10;
}
.tnews-tab {
  padding:10px 20px;border-radius:50px;
  border:1px solid #e2e8f0;background:#f8fafc;
  font-size:.88rem;font-weight:600;color:var(--text-secondary);
  cursor:pointer;transition:all .3s;font-family:inherit;
  display:inline-flex;align-items:center;gap:6px;
  white-space:nowrap;
}
.tnews-tab:hover{border-color:var(--brand);color:var(--brand);}
.tnews-tab.is-active {
  background:var(--brand);color:#fff;border-color:var(--brand);
  box-shadow:0 4px 12px rgba(92,134,7,.25);
}
.tnews-tab.is-active i{color:#fff;}
.tnews-tab i{font-size:.82rem;transition:color .3s;}

/* === Tab Panel === */
.tnews-tab-panel {
  display:none;
  padding:28px 24px;
  background:#fff;border-radius:0 0 var(--radius) var(--radius);
  box-shadow:var(--shadow);border:1px solid #eef2f7;border-top:none;
  animation:tnewsFadeIn .4s ease;
}
.tnews-tab-panel.is-visible{display:block;}
@keyframes tnewsFadeIn {
  from{opacity:0;transform:translateY(8px);}
  to{opacity:1;transform:translateY(0);}
}

/* === 延伸探索 === */
.tnews-explore {
  margin-top:24px;background:#fff;border-radius:var(--radius);
  padding:28px 36px;box-shadow:var(--shadow);border:1px solid #eef2f7;
}
.tnews-explore-title {
  font-size:1.1rem;font-weight:800;color:var(--brand-dark);
  margin:0 0 16px;display:flex;align-items:center;gap:8px;
}
.tnews-explore-grid {
  display:grid;grid-template-columns:repeat(6,1fr);gap:14px;
}
.tnews-explore-card {
  display:flex;flex-direction:column;align-items:center;text-align:center;
  gap:8px;padding:20px 12px;background:#f8fafc;border-radius:12px;
  border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);
  transition:all .3s;
}
.tnews-explore-card:hover {
  border-color:var(--brand);transform:translateY(-3px);
  box-shadow:0 6px 18px rgba(0,0,0,.06);
}
.tnews-explore-card i{font-size:22px;color:var(--brand);}
.tnews-explore-card span{font-weight:700;font-size:.9rem;}

/* === Tab 分類專屬色標 === */
.tnews-tab[data-tab="news"] i      { color:#2c5e2e; }
.tnews-tab[data-tab="event"] i     { color:#d4a017; }
.tnews-tab[data-tab="press"] i     { color:#0d7377; }
.tnews-tab[data-tab="notices"] i   { color:#6b7280; }
.tnews-tab[data-tab="podcast"] i   { color:#c62828; }
.tnews-tab[data-tab="youtube"] i   { color:#ff0000; }
.tnews-tab[data-tab="agri-school"] i { color:#92400e; }
.tnews-tab[data-tab="health"] i    { color:#e74c3c; }
.tnews-tab[data-tab="equipment"] i { color:#e67e22; }
.tnews-tab[data-tab="insurance"] i { color:#5C8607; }
.tnews-tab[data-tab="research"] i  { color:#1565c0; }
.tnews-tab.is-active[data-tab] i   { color:#fff !important; }

/* Active tab 底色跟隨分類 */
.tnews-tab.is-active[data-tab="news"]      { background:#2c5e2e;border-color:#2c5e2e; }
.tnews-tab.is-active[data-tab="event"]     { background:#b8860b;border-color:#b8860b; }
.tnews-tab.is-active[data-tab="press"]     { background:#0d7377;border-color:#0d7377; }
.tnews-tab.is-active[data-tab="notices"]   { background:#6b7280;border-color:#6b7280; }
.tnews-tab.is-active[data-tab="podcast"]   { background:#c62828;border-color:#c62828; }
.tnews-tab.is-active[data-tab="youtube"]   { background:#cc0000;border-color:#cc0000; }
.tnews-tab.is-active[data-tab="agri-school"]{ background:#92400e;border-color:#92400e; }
.tnews-tab.is-active[data-tab="health"]    { background:#e74c3c;border-color:#e74c3c; }
.tnews-tab.is-active[data-tab="equipment"] { background:#e67e22;border-color:#e67e22; }
.tnews-tab.is-active[data-tab="insurance"] { background:#5C8607;border-color:#5C8607; }
.tnews-tab.is-active[data-tab="research"]  { background:#1565c0;border-color:#1565c0; }

/* === RWD === */
@media(max-width:768px){
  .tnews-hero{flex-direction:column;padding:28px 20px;gap:20px;}
  .tnews-hero-title{font-size:1.8rem;}
  .tnews-hero-deco{justify-content:center;}
  .tnews-hero-icon{width:52px;height:52px;font-size:20px;}
  .tnews-tab-bar{padding:14px 16px;gap:6px;position:static;}
  .tnews-tab{padding:8px 14px;font-size:.82rem;}
  .tnews-tab-panel{padding:16px;}
  .tnews-explore{padding:20px;}
  .tnews-explore-grid{grid-template-columns:repeat(3,1fr);gap:10px;}
  .tnews-explore-card{padding:14px 8px;}
}
@media(max-width:480px){
  .tnews-explore-grid{grid-template-columns:repeat(2,1fr);}
  .tnews-tab-bar{justify-content:flex-start;overflow-x:auto;flex-wrap:nowrap;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
  .tnews-tab-bar::-webkit-scrollbar{display:none;}
}
</style>

<!-- ========== JavaScript ========== -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  var app = document.getElementById('tnews-app');
  if (!app) return;

  var tabs   = app.querySelectorAll('.tnews-tab');
  var panels = app.querySelectorAll('.tnews-tab-panel');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.getAttribute('data-tab');

      // 切換 tab active
      tabs.forEach(function(t) { t.classList.remove('is-active'); });
      tab.classList.add('is-active');

      // 切換 panel
      panels.forEach(function(p) {
        if (p.getAttribute('data-panel') === target) {
          p.classList.remove('is-visible');
          // 強制 reflow 以觸發動畫
          void p.offsetWidth;
          p.classList.add('is-visible');
        } else {
          p.classList.remove('is-visible');
        }
      });

      // 捲動到 tab bar 位置
      app.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  // URL hash 支援：#podcast 直接跳到對應分類
  var hash = window.location.hash.replace('#', '');
  if (hash) {
    var matchTab = app.querySelector('.tnews-tab[data-tab="' + hash + '"]');
    if (matchTab) {
      matchTab.click();
    }
  }
});
</script>

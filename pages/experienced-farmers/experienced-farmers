.senior-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(193,127,94,.18);color:#8b5e3c;font-size:.85rem;font-weight:700;padding:6px 16px;border-radius:20px;margin-bottom:14px;}
.senior-hero-title{font-size:1.9rem;font-weight:900;color:#6b3f28;margin:0 0 12px;line-height:1.25;}
.senior-hero-tagline{font-size:1.05rem;font-weight:600;color:var(--brand-dark);margin:0 0 16px;line-height:1.6;font-family:"Lora","Noto Sans TC",serif;font-style:italic;}
.senior-hero-intro{background:rgba(255,255,255,.75);border-radius:12px;padding:18px;border:1px solid rgba(193,127,94,.1);}
.senior-hero-intro p{margin:0;line-height:1.8;font-size:.95rem;color:var(--text-secondary);}

/* 數據區 */
.senior-section-title{font-size:1.25rem;font-weight:800;color:var(--brand-dark);display:flex;align-items:center;gap:10px;margin:0 0 16px;}
.senior-stats{margin-bottom:24px;}
.senior-stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:12px;}
.senior-stat-card{background:#fff;border-radius:14px;padding:18px 14px;text-align:center;border:1px solid #ececec;box-shadow:0 2px 8px rgba(0,0,0,.03);}
.senior-stat-number{font-size:2rem;font-weight:900;color:var(--brand-dark);line-height:1;margin-bottom:6px;font-family:"Lato","Noto Sans TC",sans-serif;}
.senior-stat-unit{font-size:1rem;font-weight:700;margin-left:2px;}

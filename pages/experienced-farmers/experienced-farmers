.senior-bottom-link{min-height:56px;border-radius:12px;text-decoration:none;color:#8b5e3c;font-size:1rem;font-weight:700;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;background:var(--brand-bg);border:1px solid rgba(193,127,94,.28);}


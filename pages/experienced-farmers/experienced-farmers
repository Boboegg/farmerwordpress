/* 情境卡 */
.senior-scenarios{margin-bottom:24px;}
.senior-scenario-card{display:flex;gap:14px;background:#fff;border-radius:14px;padding:18px;margin-bottom:12px;border:1px solid #ececec;border-left:5px solid var(--accent);box-shadow:0 2px 8px rgba(0,0,0,.03);transition:all .3s;}

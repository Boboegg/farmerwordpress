.senior-emergency h2{font-size:1.1rem;font-weight:800;color:#c62828;margin:0 0 12px;display:flex;align-items:center;gap:8px;}
.senior-emergency-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:10px;}
.senior-emergency-item{text-align:center;padding:14px 8px;background:#fef2f2;border-radius:10px;}
.senior-emergency-item strong{display:block;font-size:.82rem;color:#991b1b;margin-bottom:4px;}
.senior-emergency-item a{font-size:1.4rem;font-weight:900;color:#c62828;text-decoration:none;}
.senior-emergency-note{font-size:.88rem;line-height:1.6;color:var(--text-secondary);margin:0;}

/* 探索更多 */
.senior-explore{margin-bottom:20px;}
.senior-explore-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.senior-explore-card{display:flex;flex-direction:column;align-items:center;gap:8px;padding:16px 8px;background:#fff;border-radius:12px;border:1px solid #ececec;text-decoration:none;color:var(--text-primary);font-size:.85rem;font-weight:700;transition:all .3s;}
.senior-explore-card i{font-size:1.3rem;color:var(--brand);}
.senior-explore-card:hover{border-color:var(--brand);transform:translateY(-3px);box-shadow:0 4px 12px rgba(0,0,0,.06);}

/* 底部導覽 */
.senior-bottom-nav{position:fixed;left:0;right:0;bottom:0;z-index:20;background:#fff;border-top:1px solid #e5e7eb;box-shadow:0 -2px 12px rgba(0,0,0,.06);}

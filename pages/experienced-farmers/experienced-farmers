.senior-scenario-body{flex:1;min-width:0;}
.senior-scenario-body h3{font-size:1.05rem;font-weight:800;margin:0 0 8px;color:var(--text-primary);}
.senior-scenario-body p{font-size:.9rem;line-height:1.7;color:var(--text-secondary);margin:0 0 10px;}
.senior-scenario-link{font-size:.9rem;font-weight:700;color:var(--brand-dark);text-decoration:none;display:inline-flex;align-items:center;gap:4px;}
.senior-scenario-link:hover{text-decoration:underline;}

/* 計畫簡介 */
.senior-about{background:#fff;border-radius:var(--radius);padding:24px;margin-bottom:20px;border:1px solid #ececec;}
.senior-about-desc{font-size:.93rem;line-height:1.8;color:var(--text-secondary);margin:0 0 16px;}
.senior-about-pillars{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px;}
.senior-pillar{display:flex;flex-direction:column;align-items:center;gap:6px;padding:14px 8px;background:var(--brand-bg);border-radius:12px;font-size:.82rem;font-weight:700;color:var(--brand-dark);}
.senior-pillar i{font-size:1.3rem;color:var(--brand);}
.senior-about-link{font-size:.9rem;font-weight:700;color:var(--brand-dark);text-decoration:none;display:inline-flex;align-items:center;gap:6px;}.senior-about-link:hover{text-decoration:underline;}

/* CTA */
.senior-cta{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;}
.senior-cta-btn{min-height:56px;border-radius:14px;text-decoration:none;font-weight:700;font-size:1rem;display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:all .3s;}

<style>
.heat-hero,.heat-sections,.heat-crosslinks,.heat-references{
  --brand-legacy:#2e7d32;--brand-legacy-dark:#1a3a1a;--accent:#c62828;
  --text-primary:#1f2937;--text-secondary:#6b7280;--radius:16px;
  font-family:"Noto Sans TC","Lato",sans-serif;color:var(--text-primary);box-sizing:border-box;
}
.heat-hero *,.heat-sections *,.heat-crosslinks *,.heat-references *{box-sizing:border-box;}

/* Hero */
.heat-hero{padding:36px;background:linear-gradient(135deg,#ffebee 0%,#fff 60%,#ffcdd2 100%);border-radius:var(--radius);margin-bottom:36px;border:1px solid rgba(198,40,40,.1);}
.heat-hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(198,40,40,.1);color:var(--accent);padding:6px 16px;border-radius:20px;font-size:.85rem;font-weight:700;margin-bottom:14px;}
.heat-hero-title{font-size:2rem;font-weight:900;color:var(--accent);margin:0 0 8px;line-height:1.3;}
.heat-hero-subtitle{font-size:1.1rem;color:#e53935;font-weight:600;margin:0 0 18px;}
.heat-hero-intro{background:rgba(255,255,255,.75);border-radius:12px;padding:20px;margin-bottom:20px;border:1px solid rgba(198,40,40,.06);}
.heat-hero-intro p{margin:0 0 10px;line-height:1.8;font-size:1rem;}.heat-hero-intro p:last-child{margin-bottom:0;}
.heat-back-link{display:inline-flex;align-items:center;gap:6px;color:var(--brand-legacy);font-weight:700;text-decoration:none;font-size:.9rem;}
.heat-back-link:hover{text-decoration:underline;}

/* Section Cards */
.heat-sections{display:flex;flex-direction:column;gap:24px;margin-bottom:36px;}
.heat-sec-card{background:#fff;border-radius:var(--radius);overflow:hidden;box-shadow:0 4px 12px rgba(0,0,0,.04);border:1px solid #eee;}
.heat-sec-header{display:flex;align-items:center;gap:16px;padding:24px;background:rgba(198,40,40,.02);border-bottom:1px solid #f0f0f0;}
.heat-sec-icon{width:52px;height:52px;border-radius:14px;background:rgba(198,40,40,.1);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.heat-sec-header h2{font-size:1.2rem;font-weight:800;color:var(--accent);margin:0 0 4px;}
.heat-sec-header>div>p{font-size:.9rem;color:var(--text-secondary);margin:0;line-height:1.6;}
.heat-sec-body{padding:24px;}

/* Compare Grid */
.heat-compare-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:16px;}
.heat-compare-box{padding:24px;border-radius:12px;border:1px solid #eee;}
.heat-compare-danger{background:rgba(198,40,40,.03);border-color:rgba(198,40,40,.15);}
.heat-compare-warning{background:rgba(245,158,11,.03);border-color:rgba(245,158,11,.15);}
.heat-compare-box h3{font-size:1.05rem;font-weight:800;margin:0 0 14px;display:flex;align-items:center;gap:8px;}
.heat-compare-danger h3{color:#c62828;}.heat-compare-warning h3{color:#e65100;}
.heat-compare-box ul{list-style:none;padding:0;margin:0 0 14px;}
.heat-compare-box li{font-size:.9rem;line-height:1.7;padding:3px 0;padding-left:18px;position:relative;color:var(--text-primary);}
.heat-compare-box li::before{content:'•';position:absolute;left:0;font-weight:800;}
.heat-compare-danger li::before{color:#c62828;}.heat-compare-warning li::before{color:#e65100;}
.heat-compare-action{padding:12px 16px;background:rgba(255,255,255,.7);border-radius:8px;font-size:.9rem;line-height:1.7;margin-bottom:8px;}
.heat-compare-stat{font-size:.82rem;color:var(--text-secondary);margin:0;font-style:italic;}

/* Warning Box */
.heat-warning-box{padding:14px 18px;background:rgba(245,158,11,.08);border-radius:10px;border-left:4px solid #f59e0b;font-size:.9rem;line-height:1.7;display:flex;align-items:flex-start;gap:10px;color:var(--text-primary);}
.heat-warning-box i{color:#f59e0b;margin-top:3px;flex-shrink:0;}

/* Habit Grid */
.heat-habit-grid{display:flex;flex-direction:column;gap:16px;}
.heat-habit-item{display:flex;gap:16px;padding:18px;background:#f9fafb;border-radius:12px;border:1px solid #f0f0f0;}
.heat-habit-num{width:36px;height:36px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;flex-shrink:0;}
.heat-habit-item h4{font-size:1rem;font-weight:700;margin:0 0 6px;color:var(--text-primary);}
.heat-habit-item p{font-size:.9rem;line-height:1.7;color:var(--text-secondary);margin:0;}

/* Kidney Stats */
.heat-kidney-content p{font-size:.95rem;line-height:1.8;margin:0 0 16px;color:var(--text-primary);}
.heat-kidney-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:16px;}
.heat-kidney-stat{background:rgba(198,40,40,.04);border-radius:12px;padding:20px;text-align:center;border:1px solid rgba(198,40,40,.1);}
.heat-kidney-num{display:block;font-size:1.8rem;font-weight:900;color:var(--accent);margin-bottom:6px;}
.heat-kidney-stat span:last-child{font-size:.85rem;color:var(--text-secondary);line-height:1.5;}

/* SOP Steps */
.heat-sop-steps{display:flex;flex-direction:column;gap:14px;}
.heat-sop-step{display:flex;gap:16px;padding:18px;background:#f9fafb;border-radius:12px;border:1px solid #f0f0f0;}
.heat-sop-step-emergency{background:rgba(198,40,40,.04);border-color:rgba(198,40,40,.12);}
.heat-sop-num{width:36px;height:36px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;flex-shrink:0;}
.heat-sop-step h4{font-size:1rem;font-weight:700;margin:0 0 6px;color:var(--text-primary);}
.heat-sop-step p{font-size:.9rem;line-height:1.7;color:var(--text-secondary);margin:0;}

/* Resource Grid */
.heat-resource-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
.heat-resource-item{padding:20px;background:#f9fafb;border-radius:12px;border:1px solid #f0f0f0;}
.heat-resource-item h4{font-size:.95rem;font-weight:700;margin:0 0 8px;color:var(--text-primary);display:flex;align-items:center;gap:8px;}
.heat-resource-item h4 i{color:var(--accent);}
.heat-resource-item p{font-size:.9rem;line-height:1.7;color:var(--text-secondary);margin:0;}
.heat-resource-item a{color:var(--brand-legacy);font-weight:600;}

/* Cross-links */
.heat-crosslinks{margin-bottom:36px;}
.heat-crosslinks h3{font-size:1.2rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:8px;margin:0 0 16px;}
.heat-crosslink-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
.heat-crosslink-item{display:flex;flex-direction:column;gap:4px;padding:20px;background:#fff;border-radius:12px;border:1px solid #eee;text-decoration:none;color:inherit;transition:all .3s;box-shadow:0 2px 8px rgba(0,0,0,.03);}
.heat-crosslink-item:hover{transform:translateY(-4px);box-shadow:0 8px 20px rgba(0,0,0,.07);border-color:var(--brand-legacy);}
.heat-crosslink-item i{font-size:1.2rem;color:var(--brand-legacy);margin-bottom:4px;}
.heat-crosslink-item span{font-weight:700;font-size:.95rem;color:var(--brand-legacy-dark);}
.heat-crosslink-item small{font-size:.82rem;color:var(--text-secondary);line-height:1.5;}

/* References */
.heat-references{background:#f9fafb;border-radius:var(--radius);padding:28px;border:1px solid #eee;margin-bottom:36px;}
.heat-references h2{font-size:1.3rem;font-weight:800;color:var(--brand-legacy-dark);display:flex;align-items:center;gap:10px;margin:0 0 16px;}
.heat-ref-list{display:flex;flex-direction:column;gap:8px;}
.heat-ref-list p{font-size:.88rem;line-height:1.6;color:var(--text-secondary);margin:0;padding-left:20px;text-indent:-20px;}
.heat-ref-list a{color:var(--brand-legacy);word-break:break-all;}

@media(max-width:768px){
  .heat-hero{padding:24px;}.heat-hero-title{font-size:1.5rem;}
  .heat-compare-grid{grid-template-columns:1fr;}
  .heat-kidney-stats{grid-template-columns:1fr;}
  .heat-resource-grid,.heat-crosslink-grid{grid-template-columns:1fr;}
}

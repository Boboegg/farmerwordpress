.occ-benefit-card{background:#f8fafc;border-radius:14px;padding:24px;border:1px solid #e2e8f0;position:relative;transition:all .3s;}
.occ-benefit-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.08);transform:translateY(-3px);}
.occ-benefit-primary{border-color:var(--brand);border-width:2px;grid-column:1/-1;}
.occ-benefit-tag{position:absolute;top:12px;right:12px;background:var(--brand);color:#fff;padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:700;}
.occ-benefit-card h3{font-size:1.15rem;font-weight:800;margin:0 0 8px;color:var(--brand-dark);display:flex;align-items:center;gap:8px;}
.occ-benefit-card h3 i{color:var(--brand);}
.occ-benefit-purpose{font-size:.9rem;color:var(--text-secondary);margin:0 0 16px;line-height:1.5;}
.occ-benefit-detail{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;}
.occ-benefit-row{display:flex;gap:12px;font-size:.9rem;line-height:1.5;padding:6px 0;border-bottom:1px dashed #e2e8f0;}
.occ-benefit-row:last-child{border-bottom:none;}
.occ-benefit-label{font-weight:700;color:var(--brand);min-width:90px;flex-shrink:0;}
.occ-benefit-note{font-size:.83rem;color:var(--text-secondary);line-height:1.6;display:flex;align-items:flex-start;gap:6px;padding-top:8px;}
.occ-benefit-note i{color:var(--brand);margin-top:2px;flex-shrink:0;}
.occ-benefit-effective{font-size:.75rem;color:#888;margin-top:8px;text-align:right;}

/* === 官方範例（區塊3） === */
.occ-example-box{background:var(--brand-light);border-radius:14px;overflow:hidden;border:1px solid rgba(21,101,192,.15);}
.occ-example-header{background:var(--brand);color:#fff;padding:14px 24px;font-weight:700;font-size:1rem;display:flex;align-items:center;gap:8px;}
.occ-example-body{padding:24px;}
.occ-example-body p{font-size:.95rem;line-height:1.6;margin:0 0 16px;}
.occ-example-calc{display:flex;flex-direction:column;gap:8px;}
.occ-calc-item{display:flex;justify-content:space-between;padding:8px 16px;background:#fff;border-radius:8px;font-size:.93rem;}
.occ-calc-label{color:var(--text-primary);}
.occ-calc-value{font-weight:800;color:var(--brand-dark);}
.occ-calc-total{display:flex;justify-content:space-between;padding:12px 16px;background:var(--brand);color:#fff;border-radius:8px;font-size:1.05rem;font-weight:800;}
.occ-calc-total .occ-calc-value{color:#fff;}
.occ-example-source{padding:12px 24px 16px;font-size:.78rem;color:var(--text-secondary);line-height:1.5;border-top:1px solid rgba(21,101,192,.1);}

/* === 保費（區塊4） === */
.occ-premium-visual{margin-bottom:20px;}
.occ-premium-top{text-align:center;margin-bottom:20px;}
.occ-premium-formula{display:inline-block;background:#f0f4f8;padding:14px 28px;border-radius:50px;font-size:.95rem;line-height:1.5;}
.occ-premium-split{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.occ-premium-block{background:#f8fafc;border-radius:14px;padding:28px;text-align:center;border:2px solid #e2e8f0;transition:all .3s;}
.occ-premium-farmer{border-color:var(--brand);}
.occ-premium-farmer .occ-premium-amount{color:var(--brand);}
.occ-premium-gov{border-color:#15803d;}
.occ-premium-gov .occ-premium-amount{color:#15803d;}
.occ-premium-amount{font-size:2.2rem;font-weight:900;line-height:1;}
.occ-premium-label{font-size:1rem;font-weight:700;margin:8px 0 12px;color:var(--text-primary);}
.occ-premium-detail{font-size:.85rem;color:var(--text-secondary);line-height:1.7;text-align:left;}

/* === 通用提示框 === */
.occ-alert-box{display:flex;align-items:flex-start;gap:12px;padding:16px 20px;border-radius:12px;font-size:.9rem;line-height:1.6;margin-bottom:14px;}
.occ-alert-info{background:#eff6ff;border:1px solid #bfdbfe;}
.occ-alert-info i{color:#1d4ed8;}
.occ-alert-warn{background:#fffbeb;border:1px solid #fde68a;}
.occ-alert-warn i{color:#f59e0b;margin-top:2px;}
.occ-alert-neutral{background:#f3f4f6;border:1px solid #e5e7eb;}
.occ-alert-neutral i{color:#555;}
.occ-data-note{font-size:.78rem;color:#888;margin-top:8px;}

/* === 加保資格（區塊5） === */
.occ-eligibility-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px;}
.occ-elig-card{background:#f8fafc;border-radius:14px;padding:24px;border:1px solid #e2e8f0;position:relative;}
.occ-elig-num{position:absolute;top:-10px;left:20px;background:var(--brand);color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.85rem;}
.occ-elig-card h3{font-size:1.05rem;font-weight:800;color:var(--brand-dark);margin:8px 0 6px;}
.occ-elig-card p{font-size:.9rem;color:var(--text-secondary);line-height:1.6;margin:0;}
.occ-elig-tag{display:inline-block;background:var(--accent);color:#fff;padding:2px 10px;border-radius:12px;font-size:.75rem;font-weight:700;margin-bottom:6px;}
.occ-elig-highlight{background:#eff6ff;border-radius:10px;padding:12px;font-size:.85rem;line-height:1.6;margin-top:12px;display:flex;align-items:flex-start;gap:6px;}
.occ-elig-highlight i{color:var(--accent);margin-top:3px;flex-shrink:0;}
.occ-common-rules{background:#f8fafc;border-radius:12px;padding:20px;margin-bottom:24px;border:1px solid #e2e8f0;}
.occ-common-rules h3{font-size:1rem;font-weight:700;margin:0 0 12px;color:var(--brand-dark);display:flex;align-items:center;gap:8px;}
.occ-rules-list{display:flex;flex-wrap:wrap;gap:12px;}
.occ-rules-list span{display:inline-flex;align-items:center;gap:6px;font-size:.9rem;padding:6px 14px;background:#fff;border-radius:20px;border:1px solid #e2e8f0;}
.occ-rules-list span .fa-check{color:#15803d;}
.occ-rules-list span .fa-xmark{color:#dc2626;}

/* === 流程步驟（區塊5、6共用） === */
.occ-sub-title{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.occ-step-flow{display:flex;flex-direction:column;align-items:center;gap:0;margin-bottom:20px;}
.occ-step{display:flex;align-items:flex-start;gap:16px;width:100%;max-width:600px;padding:16px 20px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;}
.occ-step-wide{max-width:100%;}
.occ-step-num{width:32px;height:32px;background:var(--brand);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.9rem;flex-shrink:0;}
.occ-step-content{font-size:.95rem;line-height:1.6;}
.occ-step-sub{margin-top:8px;font-size:.88rem;color:var(--text-secondary);line-height:1.7;}
.occ-step-sub i{color:var(--brand);margin-right:4px;}
.occ-step-arrow{color:#999;font-size:.8rem;padding:4px 0;}

/* === 涵蓋範圍（區塊7） === */
.occ-coverage-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
.occ-coverage-box{background:#f8fafc;border-radius:14px;padding:24px;border:1px solid #e2e8f0;}
.occ-coverage-box h3{font-size:1.05rem;font-weight:800;color:var(--brand-dark);margin:0 0 14px;display:flex;align-items:center;gap:8px;}
.occ-coverage-box h3 i{color:var(--brand);}
.occ-coverage-disease h3 i{color:#7c3aed;}
.occ-coverage-box ul{list-style:none;padding:0;margin:0;}
.occ-coverage-box ul li{padding:6px 0;font-size:.9rem;line-height:1.5;border-bottom:1px dashed #e8e8e8;display:flex;align-items:flex-start;gap:6px;}
.occ-coverage-box ul li:last-child{border-bottom:none;}
.occ-coverage-box ul li::before{content:"•";color:var(--brand);font-weight:900;flex-shrink:0;}
.occ-coverage-disease ul li::before{color:#7c3aed;}
.occ-coverage-note{margin-top:12px;font-size:.88rem;color:#15803d;display:flex;align-items:flex-start;gap:6px;line-height:1.5;}
.occ-coverage-note i{margin-top:3px;flex-shrink:0;}
.occ-ext-link{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;background:var(--brand-light);color:var(--brand);border-radius:50px;font-weight:700;font-size:.93rem;text-decoration:none;transition:all .3s;border:1px solid rgba(21,101,192,.15);}
.occ-ext-link:hover{background:var(--brand);color:#fff;transform:translateY(-2px);}

/* === FAQ（區塊8） === */
.occ-faq-list{display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.occ-faq-item{border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;transition:border-color .3s;}
.occ-faq-item.is-open{border-color:var(--brand);}
.occ-faq-q{width:100%;display:flex;justify-content:space-between;align-items:center;padding:16px 20px;background:#f8fafc;border:none;cursor:pointer;font-size:.95rem;font-weight:700;color:var(--brand-dark);text-align:left;transition:all .3s;font-family:inherit;}
.occ-faq-q:hover{background:var(--brand-light);}
.occ-faq-q i{transition:transform .3s;color:var(--brand);}
.occ-faq-item.is-open .occ-faq-q i{transform:rotate(180deg);}
.occ-faq-a{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s ease;}
.occ-faq-item.is-open .occ-faq-a{max-height:400px;padding:16px 20px;}
.occ-faq-a p{font-size:.93rem;line-height:1.7;margin:0 0 8px;}
.occ-faq-source{font-size:.78rem;color:#888;font-style:italic;}

/* === 試算工具（區塊9） === */
.occ-tool-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.occ-tool-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:32px 24px;background:#f8fafc;border-radius:14px;border:2px solid #e2e8f0;text-decoration:none;color:var(--text-primary);transition:all .3s;}
.occ-tool-card:hover{border-color:var(--brand);transform:translateY(-5px);box-shadow:0 12px 28px rgba(21,101,192,.12);}
.occ-tool-icon{width:64px;height:64px;border-radius:50%;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:28px;margin-bottom:16px;}
.occ-tool-card h3{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 8px;}
.occ-tool-card p{font-size:.88rem;color:var(--text-secondary);line-height:1.5;margin:0 0 16px;}
.occ-tool-link{font-size:.9rem;color:var(--brand);font-weight:700;display:flex;align-items:center;gap:4px;}

/* === 免責聲明（區塊10） === */
.occ-sec-disclaimer{padding:36px;}
.occ-disclaimer-box{background:#fef3c7;border-radius:12px;padding:20px 24px;margin-bottom:28px;border:1px solid #fde68a;}
.occ-disclaimer-box h3{font-size:1rem;font-weight:800;color:#92400e;margin:0 0 8px;display:flex;align-items:center;gap:8px;}
.occ-disclaimer-box p{font-size:.88rem;color:#78350f;line-height:1.7;margin:0;}
.occ-contact-grid{margin-bottom:28px;}
.occ-contact-grid h3{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.occ-contact-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.occ-contact-item{display:flex;gap:14px;padding:18px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;font-size:.9rem;}
.occ-contact-icon{width:40px;height:40px;border-radius:10px;background:var(--brand-light);color:var(--brand);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.occ-contact-item strong{display:block;margin-bottom:4px;color:var(--brand-dark);font-size:.9rem;}
.occ-contact-item span{font-size:.85rem;color:var(--text-secondary);}
.occ-contact-use{font-size:.78rem;color:#888;margin:4px 0 0;}
.occ-references{margin-bottom:28px;}
.occ-references h3{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 12px;display:flex;align-items:center;gap:8px;}
.occ-references ol{padding-left:20px;margin:0;}
.occ-references li{font-size:.85rem;line-height:1.7;color:var(--text-secondary);margin-bottom:6px;}
.occ-references a{color:var(--brand);word-break:break-all;}
.occ-cross-links h3{font-size:1.1rem;font-weight:800;color:var(--brand-dark);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.occ-cross-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.occ-cross-card{display:flex;align-items:center;gap:14px;padding:18px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0;text-decoration:none;color:var(--text-primary);transition:all .3s;}
.occ-cross-card:hover{border-color:var(--brand);transform:translateY(-3px);box-shadow:0 6px 18px rgba(0,0,0,.06);}
.occ-cross-card i{font-size:24px;color:var(--brand);}
.occ-cross-card span{font-weight:700;font-size:.95rem;display:block;}
.occ-cross-card small{font-size:.8rem;color:var(--text-secondary);display:block;margin-top:2px;}

/* === RWD === */
@media(max-width:768px){
  .occ-hero{flex-direction:column;padding:24px;gap:24px;}
  .occ-hero-title{font-size:1.6rem;}
  .occ-hero-visual{position:static;}
  .occ-hero-stats{flex-direction:row;flex-wrap:wrap;gap:10px;}
  .occ-stat-item{flex:1;min-width:140px;padding:12px;}
  .occ-sec-card{padding:20px;}
  .occ-sec-header{flex-direction:column;gap:10px;}
  .occ-benefit-grid{grid-template-columns:1fr;}
  .occ-benefit-primary{grid-column:auto;}
  .occ-premium-split{grid-template-columns:1fr;}
  .occ-eligibility-grid{grid-template-columns:1fr;}
  .occ-coverage-grid{grid-template-columns:1fr;}
  .occ-tool-grid{grid-template-columns:1fr;}
  .occ-contact-cards{grid-template-columns:1fr;}
  .occ-cross-grid{grid-template-columns:1fr;}
  .occ-compare-table{font-size:.82rem;}
  .occ-compare-table th,.occ-compare-table td{padding:10px 8px;}
}
</style>
<script>
document.addEventListener('DOMContentLoaded',function(){
  /* FAQ 手風琴 */
  document.querySelectorAll('.occ-faq-q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=this.closest('.occ-faq-item');
      var wasOpen=item.classList.contains('is-open');
      /* 關閉所有 */
      document.querySelectorAll('.occ-faq-item.is-open').forEach(function(i){i.classList.remove('is-open');});
      /* 切換當前 */
      if(!wasOpen) item.classList.add('is-open');
    });
  });
  /* 平滑捲動 */
  document.querySelectorAll('a[href^="#occ-"]').forEach(function(a){
    a.addEventListener('click',function(e){
      var t=document.querySelector(this.getAttribute('href'));
      if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}
    });
  });
});
</script>
<!-- ========== 區塊 4：保費說明 ========== -->
<div class="occ-sections" id="occ-premium">
  <div class="occ-sec-card">
    <div class="occ-sec-header">
      <div class="occ-sec-icon"><i class="fas fa-receipt"></i></div>
      <div>
        <h2>每月只要 15 元</h2>
        <p>保費結構拆解，讓你清楚知道錢怎麼分擔。</p>
      </div>
    </div>
    <div class="occ-sec-body">
      <div class="occ-premium-visual">
        <div class="occ-premium-top">
          <div class="occ-premium-formula">
            月投保金額 <strong>20,400 元</strong> × 費率 <strong>0.19%</strong> = 保費總額 <strong>39 元/月</strong>
          </div>
        </div>
        <div class="occ-premium-split">
          <div class="occ-premium-block occ-premium-farmer">
            <div class="occ-premium-amount">15 元</div>
            <div class="occ-premium-label">農民實繳</div>
            <div class="occ-premium-detail">
              農民負擔 60% = 23 元<br>
              中央加碼補助 8 元<br>
              <strong>→ 實繳 15 元</strong>
            </div>
          </div>
          <div class="occ-premium-block occ-premium-gov">
            <div class="occ-premium-amount">24 元</div>
            <div class="occ-premium-label">政府負擔</div>
            <div class="occ-premium-detail">
              中央主管機關 30% + 縣市 10% = 16 元<br>
              中央加碼補助 = 8 元<br>
              <strong>→ 合計 24 元</strong>
            </div>
          </div>
        </div>
      </div>

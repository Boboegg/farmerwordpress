<!-- ========== 區塊 3：四項給付詳解 ========== -->
<div class="occ-sections" id="occ-benefits">
  <div class="occ-sec-card">
    <div class="occ-sec-header">
      <div class="occ-sec-icon"><i class="fas fa-hand-holding-dollar"></i></div>

  // 先預留，第二段會填入實際 items
  function populateDiseaseSelect() {
    const select = document.getElementById('select-disease');
    const list = state.identity === 'farmer' ? farmerDiseaseItems : laborInjuryDiseaseItems;

    if (!list.length) {
      select.innerHTML = '<option value="">（稍後補上職業病清單）</option>';
      state.currentDisease = null;
      document.getElementById('disease-detail').style.display = 'none';
      return;
    }

    select.innerHTML = list.map(d => `<option value="${d.id}">${d.title}</option>`).join('');
    state.currentDisease = list[0].id;
    updateDiseaseDetail();
  }

  function updateDiseaseDetail() {
    const select = document.getElementById('select-disease');
    const list = state.identity === 'farmer' ? farmerDiseaseItems : laborInjuryDiseaseItems;
    const detailDiv = document.getElementById('disease-detail');
    const item = list.find(d => d.id === select.value);
    state.currentDisease = item ? item.id : null;

    if (!item) {
      detailDiv.style.display = 'none';
      return;
    }

    const proofList = (item.proof || []).map(p => `<li class="ml-4 list-disc">${p}</li>`).join('');
    const suggestText = item.suggest || '若案件較複雜或爭議性較高，建議攜帶診斷書、工作與投保紀錄，洽詢職業醫學科或職災勞工服務中心，由專業團隊協助判斷是否屬職業傷病。';

    detailDiv.innerHTML = `
      <div class="space-y-2">
        <p class="text-xs font-bold">${item.lawRef || ''}</p>
        <p class="text-sm">${item.summary || ''}</p>
        ${proofList ? `<ul class="text-xs mt-1">${proofList}</ul>` : ''}
        <p class="text-xs mt-2 text-gray-600">${suggestText}</p>
      </div>
    `;
    detailDiv.className =
 `p-4 rounded-xl text-sm border-l-4 fade-in ${state.identity === 'farmer'
    ? 'bg-green-50 border-green-500 text-green-800'
    : 'bg-blue-50 border-blue-500 text-blue-800'}`;
    detailDiv.style.display = 'block';
  }

  function updateCalculation() {
    const salary = parseInt(document.getElementById('input-salary').value) || 0;
    const days = parseInt(document.getElementById('range-rest-days').value);
    const opDays = parseInt(document.getElementById('input-outpatient').value) || 0;
    const ipDays = parseInt(document.getElementById('input-inpatient').value) || 0;

    document.getElementById('display-rest-days').innerText = days;

    // 傷病給付計算（農民與勞工公式不同）
    const payableDays = Math.max(0, days - 3);
    const daily = salary / 30;
    let injuryBenefit = 0;

    if (state.identity === 'farmer') {
      // 農民職災保險：自第4日起，一律按投保金額70%發給，最長2年
      // 法源：農民職業災害保險試辦辦法第16條
      injuryBenefit = Math.round(payableDays * daily * 0.7);
    } else {
      // 勞工職災保險：前2個月(60個可領日)按100%，第3個月起按70%，最長2年
      // 法源：勞工職業災害保險及保護法第42條
      if (payableDays <= 60) {
        injuryBenefit = Math.round(payableDays * daily);
      } else {
        injuryBenefit = Math.round((60 * daily) + ((payableDays - 60) * daily * 0.7));
      }
    }

    // 醫療給付 / 就醫津貼
    let medicalBenefit = 0;
    if (state.identity === 'farmer') {
      // 114/11/6 以後新標準：門診100、住院1200（用門診/住院天數近似保險給付日數）
      medicalBenefit = (opDays * 100) + (ipDays * 1200);
      document.getElementById('medical-text').innerText = `\$${medicalBenefit.toLocaleString()} 元`;
      document.getElementById('medical-subtext').innerText =
        '農民職災保險就醫津貼，自第4日起依核定傷病給付日數按門診100元/日、住院1200元/日發給；此處僅以自填日數近似估算。';
    } else {
      document.getElementById('medical-text').innerText = '部分負擔減免';
      document.getElementById('medical-subtext').innerText =
        '勞工職災保險之醫療給付多採「實物給付」，由保險與健保支付多數醫療費用，勞工通常僅負擔掛號費與非健保給付項目，本工具不逐項計算。';
    }

    document.getElementById('injury-amount').innerText = injuryBenefit.toLocaleString();
    document.getElementById('total-amount').innerText = (injuryBenefit + medicalBenefit).toLocaleString();

    updateFormula(salary, days, payableDays, daily, injuryBenefit, medicalBenefit);
  }

